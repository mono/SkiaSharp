{#-
  page.md.jinja2 — the ONE place page structure lives.

  Inputs:
    data  = deterministic facts emitted by generate-release-notes.py (data.json)
    slots = prose written by the polish agent (slots.json)

  The agent NEVER writes headings, tables, banners, @handles, ❤️ or PR links.
  Those are all rendered here from `data`, so they cannot be dropped or malformed.
  The agent supplies only the prose strings referenced as `slots.*`.
-#}
<!-- RELEASE-NOTES DATA (generated, do not edit) format:{{ data.format }} version:{{ data.version }} -->
# {{ data.title }}
{{ banner_line(data, slots) }}
{%- if data.get('supersedes') %}
{%- for s in data.supersedes %}
> **Supersedes [{{ s.version }}]({{ s.href }})** · {{ s.note }}
{%- endfor %}
{%- endif %}
{%- if data.get('superseded_by') %}
> **Superseded by [{{ data.superseded_by.version }}]({{ data.superseded_by.href }})** · {{ data.superseded_by.note }}
{%- endif %}
{%- if data.get('api_links') %}
> **API changes** · {% for l in data.api_links %}[{{ l.label }}]({{ l.href }}){% if not loop.last %} · {% endif %}{% endfor %}
{%- endif %}

## Highlights

{{ slots.highlights_headline }}{% if slots.highlights_body %} {{ slots.highlights_body }}{% endif %}

## Breaking Changes
{% if slots.breaking %}
{%- for b in slots.breaking %}
- **{{ b.title }}** — {{ b.body }}{{ pr_refs(b.prs, data) }}
{%- endfor %}
{%- else %}
{{ data.breaking_none_text }}
{%- endif %}
{% for cat in slots.categories %}
## {{ cat.heading }}
{% for item in cat.bullets %}
- **{{ item.lead }}** — {{ item.detail }}{{ credit(item.prs, data) }}
{%- endfor %}
{% endfor -%}
{%- if data.get('platform_support') %}
## Platform Support

| Platform | Minimum Version |
|----------|-----------------|
{%- for row in data.platform_support %}
| {{ row.platform }} | {{ row.version }} |
{%- endfor %}
{% endif -%}
{%- if data.get('contributors') %}
## Community Contributors ❤️

Thank you to everyone who contributed to this release!

| Contributor | Contributions |
|-------------|---------------|
{%- for c in data.contributors %}
| [@{{ c.login }}]({{ c.url }}) | {{ slots.contributor_summaries[c.login] }} ({{ pr_links(c.prs, data) }}) |
{%- endfor %}
{% endif -%}
{%- if data.get('links') %}
## Links

{% for l in data.links %}- [{{ l.label }}]({{ l.href }})
{% endfor -%}
{% endif -%}
{%- for p in data.get('previews', []) %}

## {{ p.label }}{% if p.date %} ({{ p.date }}){% endif %}

{{ slots.preview_summaries[p.key] }}
{%- if p.changelog_url %}

[Full changelog]({{ p.changelog_url }})
{%- endif %}
{%- endfor %}
