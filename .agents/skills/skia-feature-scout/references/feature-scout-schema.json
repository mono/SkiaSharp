{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/mono/SkiaSharp/feature-scout-schema.json",
  "title": "Skia Feature Scout Report",
  "description": "Structured output from the Skia Feature Scout skill. Tracks upstream Skia features, their binding status in SkiaSharp, hidden APIs from C++ header scans, performance notes, and deprecation actions.",
  "type": "object",
  "required": ["meta", "summary", "items"],
  "additionalProperties": false,
  "properties": {
    "meta": {
      "type": "object",
      "required": ["date", "schemaVersion", "mode", "currentMilestone", "latestUpstreamMilestone", "releaseNotesSource"],
      "additionalProperties": false,
      "properties": {
        "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "schemaVersion": { "type": "string", "const": "2.0" },
        "mode": { "type": "string", "enum": ["full", "windowed"] },
        "previousMilestone": { "type": "integer", "minimum": 79 },
        "currentMilestone": { "type": "integer", "minimum": 79 },
        "latestUpstreamMilestone": { "type": "integer", "minimum": 79 },
        "skiaSubmoduleCommit": { "type": "string" },
        "releaseNotesSource": { "type": "string", "format": "uri" }
      }
    },
    "summary": {
      "type": "object",
      "required": ["totalItems", "full", "partial", "missing", "actionNeeded"],
      "additionalProperties": true,
      "properties": {
        "totalItems": { "type": "integer", "minimum": 0 },
        "full": { "type": "integer", "minimum": 0 },
        "partial": { "type": "integer", "minimum": 0 },
        "missing": { "type": "integer", "minimum": 0 },
        "actionNeeded": { "type": "integer", "minimum": 0 },
        "correctlyAbsent": { "type": "integer", "minimum": 0 },
        "notApplicable": { "type": "integer", "minimum": 0 },
        "hiddenApiCount": { "type": "integer", "minimum": 0 },
        "performanceCount": { "type": "integer", "minimum": 0 },
        "critical": { "type": "integer", "minimum": 0 },
        "high": { "type": "integer", "minimum": 0 },
        "medium": { "type": "integer", "minimum": 0 },
        "low": { "type": "integer", "minimum": 0 }
      }
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/featureItem" }
    },
    "hiddenApis": {
      "type": "array",
      "items": { "$ref": "#/$defs/hiddenApi" }
    },
    "deprecations": {
      "type": "array",
      "items": { "$ref": "#/$defs/deprecation" }
    },
    "performance": {
      "type": "array",
      "items": { "$ref": "#/$defs/perfNote" }
    },
    "nextSteps": {
      "type": "array",
      "items": { "$ref": "#/$defs/nextStep" }
    }
  },
  "$defs": {
    "category": {
      "type": "string",
      "enum": [
        "new_feature", "codec", "image", "image_filter", "shader",
        "color", "canvas", "path", "font", "utility",
        "performance", "behavior_change", "deprecation"
      ]
    },
    "bindingStatus": {
      "type": "string",
      "enum": ["full", "partial", "missing", "action_needed", "correctly_absent", "not_applicable"]
    },
    "priority": {
      "type": "string",
      "enum": ["critical", "high", "medium", "low"]
    },
    "apiPresence": {
      "type": "string",
      "enum": ["present", "missing", "not_applicable"]
    },
    "featureItem": {
      "type": "object",
      "required": ["id", "name", "category", "milestoneIntroduced", "skiaApi", "description", "cApiStatus", "csharpStatus", "bindingStatus", "priority"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "integer", "minimum": 1 },
        "name": { "type": "string", "minLength": 1 },
        "category": { "$ref": "#/$defs/category" },
        "milestoneIntroduced": { "type": "integer", "minimum": 79 },
        "milestoneEnhanced": { "type": ["string", "null"] },
        "milestoneDeprecated": { "type": ["integer", "null"] },
        "milestoneRemoved": { "type": ["integer", "null"] },
        "skiaApi": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "userValue": { "type": ["string", "null"] },
        "cApiStatus": { "$ref": "#/$defs/apiPresence" },
        "cApiFunction": { "type": ["string", "null"] },
        "cApiFile": { "type": ["string", "null"] },
        "csharpStatus": { "$ref": "#/$defs/apiPresence" },
        "csharpMethod": { "type": ["string", "null"] },
        "csharpFile": { "type": ["string", "null"] },
        "bindingStatus": { "$ref": "#/$defs/bindingStatus" },
        "priority": { "$ref": "#/$defs/priority" },
        "notes": { "type": ["string", "null"] }
      }
    },
    "hiddenApi": {
      "type": "object",
      "required": ["id", "cppClass", "cppHeader", "cppMethod", "description"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "integer", "minimum": 1 },
        "cppClass": { "type": "string" },
        "cppHeader": { "type": "string" },
        "cppMethod": { "type": "string" },
        "description": { "type": "string" },
        "cApiStatus": { "$ref": "#/$defs/apiPresence" },
        "csharpStatus": { "$ref": "#/$defs/apiPresence" },
        "priority": { "$ref": "#/$defs/priority" },
        "notes": { "type": ["string", "null"] }
      }
    },
    "deprecation": {
      "type": "object",
      "required": ["id", "skiaApi", "deprecatedSince", "skiasharpApi", "obsoleteMessage"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "integer", "minimum": 1 },
        "skiaApi": { "type": "string" },
        "deprecatedSince": { "type": "integer" },
        "skiasharpApi": { "type": "string" },
        "skiasharpFile": { "type": ["string", "null"] },
        "replacement": { "type": ["string", "null"] },
        "obsoleteMessage": { "type": "string" }
      }
    },
    "perfNote": {
      "type": "object",
      "required": ["id", "milestone", "area", "description", "impact"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "integer", "minimum": 1 },
        "milestone": { "type": "integer" },
        "area": { "type": "string" },
        "description": { "type": "string" },
        "impact": { "type": "string" },
        "bindingActionNeeded": { "type": "boolean" }
      }
    },
    "nextStep": {
      "type": "object",
      "required": ["priority", "severity", "action", "reason"],
      "additionalProperties": false,
      "properties": {
        "priority": { "type": "integer", "minimum": 1 },
        "severity": { "$ref": "#/$defs/priority" },
        "action": { "type": "string" },
        "milestone": { "type": ["integer", "null"] },
        "reason": { "type": "string" },
        "skillToUse": { "type": ["string", "null"] },
        "effort": {
          "type": ["string", "null"],
          "enum": ["trivial", "small", "medium", "large", null]
        }
      }
    }
  }
}
