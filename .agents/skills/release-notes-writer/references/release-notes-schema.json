{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/mono/SkiaSharp/release-notes-schema.json",
  "title": "SkiaSharp Release Notes",
  "description": "Structured release notes generated by diffing two SkiaSharp git refs. Contains unified findings array plus pre-rendered markdown for marketing slides and detailed changelog.",
  "type": "object",
  "required": ["meta", "summary", "findings", "slides", "changelog"],
  "additionalProperties": false,
  "properties": {
    "meta": {
      "type": "object",
      "required": ["date", "schemaVersion", "repo", "refFrom", "refTo", "shaFrom", "shaTo", "commitCount"],
      "additionalProperties": false,
      "properties": {
        "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "schemaVersion": { "type": "string", "const": "1.0" },
        "repo": { "type": "string" },
        "refFrom": { "type": "string", "minLength": 1 },
        "refTo": { "type": "string", "minLength": 1 },
        "shaFrom": { "type": "string", "minLength": 7 },
        "shaTo": { "type": "string", "minLength": 7 },
        "dateFrom": { "type": "string" },
        "dateTo": { "type": "string" },
        "commitCount": { "type": "integer", "minimum": 0 },
        "prCount": { "type": "integer", "minimum": 0 },
        "skiaMilestoneBumped": { "type": "boolean" },
        "skiaMilestoneFrom": { "type": "integer", "minimum": 79 },
        "skiaMilestoneTo": { "type": "integer", "minimum": 79 }
      }
    },
    "summary": {
      "type": "object",
      "required": ["totalFindings"],
      "additionalProperties": true,
      "properties": {
        "totalFindings": { "type": "integer", "minimum": 0 },
        "byChangeType": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "byImportance": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "byLabel": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/finding" }
    },
    "slides": {
      "type": "string",
      "description": "Pre-rendered marketing slides markdown"
    },
    "changelog": {
      "type": "string",
      "description": "Pre-rendered detailed changelog markdown"
    }
  },
  "$defs": {
    "changeType": {
      "type": "string",
      "enum": ["added", "changed", "fixed", "deprecated", "removed", "dependency", "platform"]
    },
    "importance": {
      "type": "string",
      "enum": ["breaking", "major", "minor", "patch"]
    },
    "finding": {
      "type": "object",
      "required": ["name", "changeType", "importance", "description"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "changeType": { "$ref": "#/$defs/changeType" },
        "importance": { "$ref": "#/$defs/importance" },
        "description": { "type": "string", "minLength": 1 },
        "labels": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Freeform tags: security, skia-upstream, breaking-change, new-platform, performance, deprecation"
        },
        "pr": { "type": "integer" },
        "prUrl": { "type": "string", "format": "uri" },
        "commit": { "type": "string" },
        "commitUrl": { "type": "string", "format": "uri" },
        "issue": { "type": "integer" },
        "issueUrl": { "type": "string", "format": "uri" },
        "author": { "type": "string" },
        "affectedTypes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "affectedMethods": {
          "type": "array",
          "items": { "type": "string" }
        },
        "cApiFunction": { "type": "string" },
        "csharpMethod": { "type": "string" },
        "csharpFile": { "type": "string" },
        "skiaFeature": { "type": "string" },
        "skiaMilestone": { "type": "integer", "minimum": 79 },
        "dependencyName": { "type": "string" },
        "dependencyFrom": { "type": "string" },
        "dependencyTo": { "type": "string" },
        "platforms": {
          "type": "array",
          "items": { "type": "string" }
        },
        "migrationGuide": { "type": "string" },
        "slideBullet": { "type": "string" },
        "notes": { "type": "string" }
      }
    }
  }
}
