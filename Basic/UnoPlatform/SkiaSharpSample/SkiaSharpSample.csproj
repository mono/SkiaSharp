<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="Uno.Sdk/6.6.0-dev.208">
  <PropertyGroup>
    <TargetFrameworks>net10.0-desktop;net10.0-browserwasm</TargetFrameworks>
    <TargetFrameworks Condition="$([MSBuild]::IsOSPlatform('windows'))">net10.0-windows10.0.19041.0;$(TargetFrameworks)</TargetFrameworks>
    <TargetFrameworks Condition="$([MSBuild]::IsOSPlatform('windows')) or $([MSBuild]::IsOSPlatform('OSX'))">net10.0-android;net10.0-ios;$(TargetFrameworks)</TargetFrameworks>
    <OutputType>Exe</OutputType>
    <UnoSingleProject>true</UnoSingleProject>
    <ApplicationTitle>SkiaSharpSample</ApplicationTitle>
    <ApplicationId>com.companyname.SkiaSharpSample</ApplicationId>
    <ApplicationDisplayVersion>1.0</ApplicationDisplayVersion>
    <ApplicationVersion>1</ApplicationVersion>
    <ApplicationPublisher>O=SkiaSharpSample</ApplicationPublisher>
    <Description>SkiaSharpSample powered by Uno Platform.</Description>
    <UnoFeatures>
      <!--
              Comment SkiaRenderer out to test SKSwapChainPanel which only works with
              Uno native rendering
            -->
            SkiaRenderer;
            Skia;
        </UnoFeatures>
  </PropertyGroup>
  <PropertyGroup>
    <!-- We use project references for SkiaSharp, not the NuGet packages that Uno SDK adds implicitly -->
    <UnoDisableLottieSkiaVersionCheck>true</UnoDisableLottieSkiaVersionCheck>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="SkiaSharp" Version="4.147.0-preview.1.1" />
    <PackageReference Include="HarfBuzzSharp" Version="8.3.1.3-preview.1.1" />
    <PackageReference Include="SkiaSharp.HarfBuzz" Version="4.147.0-preview.1.1" />
    <PackageReference Include="SkiaSharp.Views.Uno.WinUI" Version="4.147.0-preview.1.1" />
  </ItemGroup>
  <ItemGroup>
    <Compile Update="MainPage.utils.cs" DependentUpon="MainPage.xaml" />
  </ItemGroup>
</Project>