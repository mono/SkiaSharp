<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <!-- if ShouldIncludeNativeSkiaSharp == False then don't include the native libSkiaSharp -->
  <PropertyGroup>
    <ShouldIncludeNativeSkiaSharp Condition=" '$(ShouldIncludeNativeSkiaSharp)' == '' ">True</ShouldIncludeNativeSkiaSharp>
  </PropertyGroup>

  <!-- If this is an UNO Platform app -->
  <ItemGroup Condition="'$(IsUnoHead)' == 'True' and '$(UnoRuntimeIdentifier)' == 'WebAssembly' and '$(ShouldIncludeNativeSkiaSharp)' == 'True'">
    <Content Include="@(SkiaSharpStaticLibrary)" Visible="false" />
  </ItemGroup>
  <ItemGroup Condition="'$(IsUnoHead)' == 'True' and '$(UnoRuntimeIdentifier)' == 'WebAssembly' and '$(ShouldIncludeNativeSkiaSharp)' == 'True'">
    <WasmShellEmccExportedRuntimeMethod Include="GL" />
    <WasmShellEmccExportedRuntimeMethod Include="WebGPU" />
    <!-- Include the emscripten_gl* symbols -->
    <WasmShellExtraEmccFlags Include="-s USE_WEBGL2=1"/>
    <!-- Enable GLCtx when threading is available -->
    <WasmShellExtraEmccFlags Condition="'$(WasmShellEnableThreads)'=='True'" Include="-s OFFSCREEN_FRAMEBUFFER=1" />
    <WasmShellExtraEmccFlags Include="-s USE_WEBGPU=1"/>
  </ItemGroup>

  <!-- If this is a .NET web assembly app -->
  <PropertyGroup Condition="('$(UsingMicrosoftNETSdkBlazorWebAssembly)' == 'true' or '$(UsingMicrosoftNETSdkWebAssembly)' == 'true') and '$(ShouldIncludeNativeSkiaSharp)' == 'True'">
    <WasmBuildNative Condition="'$(WasmBuildNative)' == ''">true</WasmBuildNative>
    <!--
      net8.x (emsdk 3.1.34) uses the built-in `-sUSE_WEBGPU=1`; net9.0+ uses
      Dawn's emdawnwebgpu port, which ships in this NuGet at
      buildTransitive/netstandard1.0/emdawnwebgpu_pkg/. Discriminate on
      $(TargetFramework) directly — $(TargetFrameworkVersion) is populated by a
      later SDK import so it's still empty here.
    -->
    <_SkiaSharpUseEmdawnwebgpu Condition="'$(_SkiaSharpUseEmdawnwebgpu)' == '' and '$(TargetFramework)' != '' and !$(TargetFramework.StartsWith('net8.'))">true</_SkiaSharpUseEmdawnwebgpu>
    <!-- Normalize to forward slashes: emcc parses `-isystem <abs-path>` as one
         shell arg and swallows Windows backslashes. -->
    <_SkiaSharpEmdawnwebgpuPkg>$([System.String]::Copy('$(MSBuildThisFileDirectory)emdawnwebgpu_pkg').Replace('\','/'))</_SkiaSharpEmdawnwebgpuPkg>
    <!--
      Inline the port's inputs rather than emcc's ports mechanism: that
      compiles into emcc's cache (needs FROZEN_CACHE=0), and the .NET WASM SDK's
      FROZEN_CACHE=1 + parallel compile races on sysroot_install.stamp. Passing
      the include paths, JS libraries, and webgpu.cpp directly replicates the
      port without touching the cache; -sDEFAULT_TO_CXX=1 keeps LINK_AS_CXX on.
    -->
    <_SkiaSharpEmdawnwebgpuFlags Condition="'$(_SkiaSharpUseEmdawnwebgpu)' == 'true'">-s DEFAULT_TO_CXX=1 -isystem $(_SkiaSharpEmdawnwebgpuPkg)/webgpu/include -isystem $(_SkiaSharpEmdawnwebgpuPkg)/webgpu_cpp/include --js-library=$(_SkiaSharpEmdawnwebgpuPkg)/webgpu/src/library_webgpu_enum_tables.js --js-library=$(_SkiaSharpEmdawnwebgpuPkg)/webgpu/src/library_webgpu_generated_struct_info.js --js-library=$(_SkiaSharpEmdawnwebgpuPkg)/webgpu/src/library_webgpu_generated_sig_info.js --js-library=$(_SkiaSharpEmdawnwebgpuPkg)/webgpu/src/library_webgpu.js -std=c++20 $(_SkiaSharpEmdawnwebgpuPkg)/webgpu/src/webgpu.cpp</_SkiaSharpEmdawnwebgpuFlags>
    <EmccExtraLDFlags Condition="'$(_SkiaSharpUseEmdawnwebgpu)' == 'true'">$(EmccExtraLDFlags) -s USE_WEBGL2=1 $(_SkiaSharpEmdawnwebgpuFlags)</EmccExtraLDFlags>
    <EmccExtraLDFlags Condition="'$(_SkiaSharpUseEmdawnwebgpu)' != 'true'">$(EmccExtraLDFlags) -s USE_WEBGL2=1 -s USE_WEBGPU=1</EmccExtraLDFlags>
    <!-- Pick the threading type: 'mt' for multi-threading or 'st' for single-threading -->
    <_SkiaSharpNativeBinaryType Condition="'$(WasmEnableThreads)' == 'True'">mt</_SkiaSharpNativeBinaryType>
    <_SkiaSharpNativeBinaryType Condition="'$(WasmEnableThreads)' != 'True'">st</_SkiaSharpNativeBinaryType>
    <!-- Pick the SIMD support: 'simd' for supported or '' for not-supported -->
    <_SkiaSharpNativeBinaryType Condition="'$(WasmEnableSIMD)' == 'True'">$(_SkiaSharpNativeBinaryType),simd</_SkiaSharpNativeBinaryType>
    <_SkiaSharpNativeBinaryType Condition="'$(WasmEnableSIMD)' != 'True'">$(_SkiaSharpNativeBinaryType)</_SkiaSharpNativeBinaryType>
  </PropertyGroup>
  <ItemGroup Condition="('$(UsingMicrosoftNETSdkBlazorWebAssembly)' == 'true' or '$(UsingMicrosoftNETSdkWebAssembly)' == 'true') and '$(TargetFrameworkVersion)' != '' and '$(ShouldIncludeNativeSkiaSharp)' == 'True'">
    <!-- SkiaSharp's interop reads Module.WebGPU.{mgr*,importJs*}, so export the
         WebGPU runtime method. -->
    <EmccExportedRuntimeMethod Include="WebGPU" />
    <!-- emdawnwebgpu allocates refcounted WGPUTexture handles; the managed
         interop releases them via the C ABI's wgpuTextureRelease, so export it
         as Module._wgpuTextureRelease. -->
    <EmccExportedFunction Include="_wgpuTextureRelease" Condition="'$(_SkiaSharpUseEmdawnwebgpu)' == 'true'" />
    <!-- Skia's DawnBackendContext needs a real WGPUInstance* — the emdawnwebgpu
         port's wgpuCreateInstance returns one. Export it as Module._wgpuCreateInstance
         so the managed WebGPU shim can call it instead of falling back to a fake
         handle (a bogus pointer would hang inside wgpu::Instance::AddRef). -->
    <EmccExportedFunction Include="_wgpuCreateInstance" Condition="'$(_SkiaSharpUseEmdawnwebgpu)' == 'true'" />
    <!-- net8.0 -->
    <NativeFileReference Include="$(SkiaSharpStaticLibraryPath)/3.1.34/$(_SkiaSharpNativeBinaryType)/*.a" Condition="$([MSBuild]::VersionEquals($(TargetFrameworkVersion), '8.0'))" />
    <!-- net9.0+ -->
    <NativeFileReference Include="$(SkiaSharpStaticLibraryPath)/3.1.56/$(_SkiaSharpNativeBinaryType)/*.a" Condition="$([MSBuild]::VersionGreaterThanOrEquals($(TargetFrameworkVersion), '9.0'))" />
  </ItemGroup>

  <!-- Error when targeting unsupported WASM TFMs -->
  <Target Name="_SkiaSharpCheckWasmTfm" BeforeTargets="PrepareForBuild"
          Condition="(('$(UsingMicrosoftNETSdkBlazorWebAssembly)' == 'true' or '$(UsingMicrosoftNETSdkWebAssembly)' == 'true') or ('$(IsUnoHead)' == 'True' and '$(UnoRuntimeIdentifier)' == 'WebAssembly')) and '$(TargetFrameworkVersion)' != '' and '$(ShouldIncludeNativeSkiaSharp)' == 'True' and $([MSBuild]::VersionLessThan($(TargetFrameworkVersion), '8.0'))">
    <Error Text="SkiaSharp WebAssembly native assets require .NET 8.0 or later. Please update your project to target net8.0 or newer." />
  </Target>

  <!-- Workaround for https://github.com/dotnet/runtime/issues/109289 -->
  <Target Name="_SkiaSharpRuntimeIssue109289Workaround" AfterTargets="_BrowserWasmWriteRspForLinking">
    <ItemGroup>
      <!-- Remove the relevant args from the items -->
      <_WasmLinkStepArgs Remove="@(_EmccLinkStepArgs)" />
      <_EmccLinkStepArgs Remove="&quot;%(_WasmNativeFileForLinking.Identity)&quot;" />
      <_WasmLinkDependencies Remove="@(_WasmNativeFileForLinking)" />

      <!-- Find the libSkiaSharp binaries -->
      <_SkiaSharpToReorder Include="@(_WasmNativeFileForLinking)" Condition="$([System.String]::Copy('%(FullPath)').Contains('libSkiaSharp.a'))" />

      <!-- Remove the libSkiaSharp binary and add it back, but at the end -->
      <_WasmNativeFileForLinking Remove="@(_SkiaSharpToReorder)" />
      <_WasmNativeFileForLinking Include="@(_SkiaSharpToReorder)" />

      <!-- Add all the args back -->
      <_EmccLinkStepArgs Include="&quot;%(_WasmNativeFileForLinking.Identity)&quot;" />
      <_WasmLinkDependencies Include="@(_WasmNativeFileForLinking)" />
      <_WasmLinkStepArgs Include="@(_EmccLinkStepArgs)" />
    </ItemGroup>
  </Target>

</Project>