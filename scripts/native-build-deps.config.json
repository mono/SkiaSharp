{
  "_comment": "Dependency graph configuration. Declares what to scan and how files connect.",

  "scan": [
    "native/**/*",
    "scripts/infra/**/*",
    "scripts/cake/**/*",
    "scripts/azure-*.yml",
    "build.cake"
  ],

  "targets": [
    "native/*/build.cake"
  ],

  "global": [
    "scripts/infra/shared/**/*"
  ],

  "submodules": [
    "externals/skia"
  ],

  "links": [
    {
      "_comment": "Cake #load directives",
      "files": "**/*.cake",
      "pattern": "^#load\\s+\"([^\"]+)\"",
      "resolve": "relative"
    },
    {
      "_comment": "YAML template references",
      "files": "**/*.yml",
      "pattern": "template:\\s*/scripts/([^@\\s]+)",
      "resolve": "prefix",
      "prefix": "scripts/"
    },
    {
      "_comment": "YAML referencing native build targets",
      "files": "**/*.yml",
      "pattern": "target:\\s*externals-([a-z-]+)",
      "resolve": "prefix",
      "prefix": "native/",
      "suffix": "/build.cake"
    },
    {
      "_comment": "YAML referencing Docker contexts",
      "files": "**/*.yml",
      "pattern": "docker:\\s*(scripts/infra/[^\\s]+)",
      "resolve": "root"
    },
    {
      "_comment": "YAML script invocations",
      "files": "**/*.yml",
      "pattern": "(?:\\./|.\\\\)?scripts[/\\\\]infra[/\\\\]([a-zA-Z0-9_./-]+\\.(?:ps1|sh))",
      "resolve": "prefix",
      "prefix": "scripts/infra/"
    },
    {
      "_comment": "Docker contexts — Dockerfile pulls in all sibling files",
      "files": "**/Dockerfile",
      "siblings": true
    }
  ],

  "exclude": [
    "**/bin/**",
    "**/obj/**",
    "**/libs/**",
    "**/tools/**",
    "**/.git/**"
  ]
}
