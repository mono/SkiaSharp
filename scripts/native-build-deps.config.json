{
  "_comment": "Dependency graph configuration. Declares what to scan and how files connect.",

  "scan": [
    "native/**/*",
    "scripts/cake/**/*",
    "scripts/Docker/**/*",
    "scripts/VERSIONS.txt",
    "build.cake"
  ],

  "targets": [
    "native/*/build.cake"
  ],

  "global": [
    "scripts/VERSIONS.txt"
  ],

  "submodules": [
    "externals/skia"
  ],

  "links": [
    {
      "_comment": "Cake #load directives — file A loads file B",
      "files": "**/*.cake",
      "pattern": "^#load\\s+\"([^\"]+)\"",
      "resolve": "relative"
    },
    {
      "_comment": "Docker contexts — a Dockerfile pulls in all sibling files",
      "files": "**/Dockerfile",
      "siblings": true
    }
  ],

  "exclude": [
    "**/bin/**",
    "**/obj/**",
    "**/libs/**",
    "**/tools/**",
    "**/.git/**"
  ]
}
