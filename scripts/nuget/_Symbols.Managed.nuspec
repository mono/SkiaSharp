<?xml version="1.0" encoding="utf-8"?>
<package>
  <metadata>

    <id>_Symbols.Managed</id>
    <title>Build Symbols (Managed)</title>
    <version>1.0.0</version>
    <description>All the stable managed symbol packages from the build (excludes native assets).</description>
    <summary>All the stable managed symbol packages from the build.</summary>
    <authors>Microsoft</authors>
    <readme>README.md</readme>

  </metadata>
  <files>

    <file src="*.symbols.nupkg" exclude="_*;*-*;*NativeAssets*" target="tools/" />
    <file src="*.snupkg" exclude="_*;*-*;*NativeAssets*" target="tools/" />

  </files>
</package>
