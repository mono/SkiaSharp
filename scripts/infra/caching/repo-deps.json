{
  "include": [
    "scripts/VERSIONS.txt",
    "scripts/infra/shared/**",
    "nuget.config",
    "global.json"
  ],
  "exclude": [
    "documentation/**",
    "images/**",
    "interactive/**",
    ".github/**",
    ".devcontainer/**",
    ".vscode/**",
    ".agents/**",
    "*.md",
    ".config/**",
    ".editorconfig",
    ".gitattributes",
    ".gitignore",
    ".gitmodules",
    "build.ps1",
    "build.sh",
    "externals/.gitignore",
    "native/.gitignore",
    "scripts/azure-*.yml",
    "scripts/get-skiasharp-pr.*",
    "scripts/infra/caching/**",
    "scripts/infra/security/**",
    "cgmanifest.json",
    "utils/SkiaSharpGenerator/**",
    "utils/Utils.sln",
    "utils/generate.ps1",
    "utils/README.md"
  ],
  "jobs": {
    "native": {
      "include": [
        "scripts/infra/native/shared/**"
      ],
      "submodules": [
        "externals/skia",
        "externals/depot_tools"
      ],
      "children": {
        "android": {
          "include": [
            "native/android/**",
            "scripts/infra/native/android/**"
          ]
        },
        "ios": {
          "include": [
            "native/ios/**",
            "scripts/infra/native/apple/**"
          ]
        },
        "macos": {
          "include": [
            "native/macos/**",
            "scripts/infra/native/apple/**"
          ]
        },
        "maccatalyst": {
          "include": [
            "native/maccatalyst/**",
            "scripts/infra/native/apple/**",
            "native/ios/**"
          ]
        },
        "tvos": {
          "include": [
            "native/tvos/**",
            "scripts/infra/native/apple/**"
          ]
        },
        "windows": {
          "include": [
            "native/windows/**",
            "scripts/infra/native/windows/**"
          ]
        },
        "winui": {
          "include": [
            "native/winui/**",
            "scripts/infra/native/windows/**"
          ]
        },
        "winui_angle": {
          "include": [
            "native/winui-angle/**",
            "scripts/infra/native/windows/**"
          ]
        },
        "nanoserver": {
          "include": [
            "native/nanoserver/**",
            "scripts/infra/native/windows/**",
            "native/windows/**"
          ]
        },
        "linux": {
          "include": [
            "native/linux/**",
            "scripts/infra/native/linux/**"
          ]
        },
        "linux_cross": {
          "include": [
            "native/linux-clang-cross/**",
            "scripts/infra/native/linux/**",
            "native/linux/**"
          ]
        },
        "linuxnodeps": {
          "include": [
            "native/linuxnodeps/**",
            "scripts/infra/native/linux/**",
            "native/linux/**"
          ]
        },
        "tizen": {
          "include": [
            "native/tizen/**",
            "scripts/infra/native/tizen/**"
          ]
        },
        "wasm": {
          "include": [
            "native/wasm/**",
            "scripts/infra/native/wasm/**"
          ]
        }
      }
    },
    "managed": {
      "include": [
        "binding/**",
        "source/**",
        "scripts/infra/managed/**",
        "scripts/mono.*",
        "build.cake",
        "LICENSE.txt",
        "images/nuget.png",
        "External-Dependency-Info.txt"
      ],
      "submodules": [
        "docs"
      ],
      "children": {
        "package": {
          "include": [
            "scripts/infra/package/**"
          ],
          "children": {
            "api_diff": {
              "include": [
                "scripts/infra/docs/**",
                "changelogs/**"
              ]
            }
          }
        },
        "tests": {
          "include": [
            "tests/**",
            "scripts/infra/tests/**",
            "benchmarks/**",
            "utils/WasmTestRunner/**",
            "utils/NativeLibraryMiniTest/**"
          ]
        },
        "samples": {
          "include": [
            "samples/**",
            "scripts/infra/samples/**"
          ]
        }
      }
    }
  }
}
