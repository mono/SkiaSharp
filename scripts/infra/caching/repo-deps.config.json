{
  "_comment": "Repository dependency graph with path inheritance via depends_on.",
  "ignore": [
    "_comment: Files matching these patterns trigger NO stages",
    "documentation/**",
    "images/**",
    "interactive/**",
    ".github/**",
    ".devcontainer/**",
    ".vscode/**",
    ".agents/**",
    "*.md",
    "LICENSE.*",
    "CODE-OF-CONDUCT.md",
    "CONTRIBUTING.md",
    "External-Dependency-Info.txt",
    "cgmanifest.json",
    ".config/**",
    ".editorconfig",
    ".gitattributes",
    ".gitignore",
    ".gitmodules",
    "build.ps1",
    "build.sh",
    "externals/.gitignore",
    "native/.gitignore",
    "scripts/azure-*.yml",
    "scripts/get-skiasharp-pr.*",
    "scripts/infra/caching/**",
    "scripts/infra/security/**",
    "scripts/mono.*"
  ],
  "jobs": {
    "shared": {
      "_comment": "Global — affects everything",
      "paths": [
        "scripts/VERSIONS.txt"
      ]
    },
    "native_shared": {
      "_comment": "Shared native infra — affects all native platforms",
      "depends_on": [
        "shared"
      ],
      "paths": [
        "scripts/infra/native/shared/**"
      ],
      "submodules": [
        "externals/skia",
        "externals/depot_tools"
      ]
    },
    "native_android": {
      "depends_on": [
        "native_shared"
      ],
      "paths": [
        "native/android/**",
        "scripts/infra/native/android/**"
      ]
    },
    "native_ios": {
      "depends_on": [
        "native_shared"
      ],
      "paths": [
        "native/ios/**",
        "scripts/infra/native/apple/**"
      ]
    },
    "native_macos": {
      "depends_on": [
        "native_shared"
      ],
      "paths": [
        "native/macos/**",
        "scripts/infra/native/apple/**"
      ]
    },
    "native_maccatalyst": {
      "depends_on": [
        "native_shared"
      ],
      "paths": [
        "native/maccatalyst/**",
        "native/ios/**",
        "scripts/infra/native/apple/**"
      ]
    },
    "native_tvos": {
      "depends_on": [
        "native_shared"
      ],
      "paths": [
        "native/tvos/**",
        "scripts/infra/native/apple/**"
      ]
    },
    "native_windows": {
      "depends_on": [
        "native_shared"
      ],
      "paths": [
        "native/windows/**",
        "scripts/infra/native/windows/**"
      ]
    },
    "native_winui": {
      "depends_on": [
        "native_shared"
      ],
      "paths": [
        "native/winui/**",
        "scripts/infra/native/windows/**"
      ]
    },
    "native_winui_angle": {
      "depends_on": [
        "native_shared"
      ],
      "paths": [
        "native/winui-angle/**",
        "scripts/infra/native/windows/**"
      ]
    },
    "native_nanoserver": {
      "depends_on": [
        "native_shared"
      ],
      "paths": [
        "native/nanoserver/**",
        "native/windows/**",
        "scripts/infra/native/windows/**"
      ]
    },
    "native_linux": {
      "depends_on": [
        "native_shared"
      ],
      "paths": [
        "native/linux/**",
        "scripts/infra/native/linux/**"
      ]
    },
    "native_linux_cross": {
      "depends_on": [
        "native_shared"
      ],
      "paths": [
        "native/linux-clang-cross/**",
        "native/linux/**",
        "scripts/infra/native/linux/**"
      ]
    },
    "native_linuxnodeps": {
      "depends_on": [
        "native_shared"
      ],
      "paths": [
        "native/linuxnodeps/**",
        "native/linux/**",
        "scripts/infra/native/linux/**"
      ]
    },
    "native_tizen": {
      "depends_on": [
        "native_shared"
      ],
      "paths": [
        "native/tizen/**",
        "scripts/infra/native/tizen/**"
      ]
    },
    "native_wasm": {
      "depends_on": [
        "native_shared"
      ],
      "paths": [
        "native/wasm/**",
        "scripts/infra/native/wasm/**"
      ]
    },
    "managed": {
      "depends_on": [
        "shared"
      ],
      "paths": [
        "binding/**",
        "source/**",
        "utils/**",
        "scripts/infra/managed/**",
        "build.cake",
        "nuget.config",
        "global.json"
      ],
      "submodules": [
        "docs"
      ]
    },
    "package": {
      "depends_on": [
        "managed"
      ],
      "paths": [
        "scripts/infra/package/**"
      ]
    },
    "tests": {
      "depends_on": [
        "managed"
      ],
      "paths": [
        "tests/**",
        "scripts/infra/tests/**",
        "benchmarks/**"
      ]
    },
    "samples": {
      "depends_on": [
        "managed"
      ],
      "paths": [
        "samples/**"
      ]
    },
    "api_diff": {
      "depends_on": [
        "package"
      ],
      "paths": [
        "changelogs/**"
      ]
    }
  }
}
