{
  "_comment": "Repository dependency graph. Maps file paths to pipeline stages.",

  "scan": [
    "native/**/*",
    "binding/**/*",
    "source/**/*",
    "tests/**/*",
    "samples/**/*",
    "scripts/infra/**/*",
    "scripts/azure-*.yml",
    "scripts/VERSIONS.txt",
    "build.cake",
    "nuget.config",
    "global.json"
  ],

  "stages": {
    "native": {
      "_comment": "C/C++ native library compilation",
      "targets": ["native/*/build.cake"],
      "paths": [
        "externals/skia",
        "native/**",
        "scripts/infra/native/**",
        "scripts/VERSIONS.txt"
      ]
    },
    "managed": {
      "_comment": "C# managed library build",
      "depends_on": ["native"],
      "paths": [
        "binding/**",
        "source/**",
        "scripts/infra/managed/**",
        "build.cake",
        "nuget.config",
        "global.json"
      ]
    },
    "package": {
      "_comment": "NuGet package creation",
      "depends_on": ["managed"],
      "paths": [
        "scripts/infra/package/**"
      ]
    },
    "tests": {
      "_comment": "Test execution",
      "depends_on": ["managed"],
      "paths": [
        "tests/**",
        "scripts/infra/tests/**"
      ]
    },
    "samples": {
      "_comment": "Sample project builds",
      "depends_on": ["managed"],
      "paths": [
        "samples/**"
      ]
    },
    "api_diff": {
      "_comment": "API diff and documentation",
      "depends_on": ["package"],
      "paths": [
        "docs/**",
        "changelogs/**"
      ]
    }
  },

  "global": [
    "scripts/infra/native/shared/**/*",
    "scripts/VERSIONS.txt"
  ],

  "submodules": [
    "externals/skia"
  ],

  "links": [
    {
      "_comment": "Cake #load directives",
      "files": "**/*.cake",
      "pattern": "^#load\\s+\"([^\"]+)\"",
      "resolve": "relative"
    },
    {
      "_comment": "YAML template references",
      "files": "**/*.yml",
      "pattern": "template:\\s*/scripts/([^@\\s]+)",
      "resolve": "prefix",
      "prefix": "scripts/"
    },
    {
      "_comment": "YAML referencing native build targets",
      "files": "**/*.yml",
      "pattern": "target:\\s*externals-([a-z-]+)",
      "resolve": "prefix",
      "prefix": "native/",
      "suffix": "/build.cake"
    },
    {
      "_comment": "YAML referencing Docker contexts",
      "files": "**/*.yml",
      "pattern": "docker:\\s*(scripts/infra/[^\\s]+)",
      "resolve": "root"
    },
    {
      "_comment": "YAML script invocations",
      "files": "**/*.yml",
      "pattern": "(?:\\./|.\\\\)?scripts[/\\\\]infra[/\\\\]([a-zA-Z0-9_./-]+\\.(?:ps1|sh))",
      "resolve": "prefix",
      "prefix": "scripts/infra/"
    },
    {
      "_comment": "Docker contexts — Dockerfile pulls in all sibling files",
      "files": "**/Dockerfile",
      "siblings": true
    }
  ],

  "exclude": [
    "**/bin/**",
    "**/obj/**",
    "**/libs/**",
    "**/tools/**",
    "**/.git/**"
  ]
}

# v2
