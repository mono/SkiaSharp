{
  "_comment": "Repository dependency graph. Maps file paths to pipeline stages.",

  "stages": {
    "native_android": {
      "paths": ["native/android/**", "scripts/infra/native/shared/**", "scripts/infra/native/android/**", "scripts/VERSIONS.txt"],
      "submodules": ["externals/skia", "externals/depot_tools"]
    },
    "native_ios": {
      "paths": ["native/ios/**", "scripts/infra/native/shared/**", "scripts/infra/native/apple/**", "scripts/VERSIONS.txt"],
      "submodules": ["externals/skia", "externals/depot_tools"]
    },
    "native_macos": {
      "paths": ["native/macos/**", "scripts/infra/native/shared/**", "scripts/infra/native/apple/**", "scripts/VERSIONS.txt"],
      "submodules": ["externals/skia", "externals/depot_tools"]
    },
    "native_maccatalyst": {
      "paths": ["native/maccatalyst/**", "scripts/infra/native/shared/**", "scripts/infra/native/apple/**", "scripts/VERSIONS.txt"],
      "submodules": ["externals/skia", "externals/depot_tools"]
    },
    "native_tvos": {
      "paths": ["native/tvos/**", "scripts/infra/native/shared/**", "scripts/infra/native/apple/**", "scripts/VERSIONS.txt"],
      "submodules": ["externals/skia", "externals/depot_tools"]
    },
    "native_windows": {
      "paths": ["native/windows/**", "scripts/infra/native/shared/**", "scripts/infra/native/windows/**", "scripts/VERSIONS.txt"],
      "submodules": ["externals/skia", "externals/depot_tools"]
    },
    "native_winui": {
      "paths": ["native/winui/**", "scripts/infra/native/shared/**", "scripts/infra/native/windows/**", "scripts/VERSIONS.txt"],
      "submodules": ["externals/skia", "externals/depot_tools"]
    },
    "native_winui_angle": {
      "paths": ["native/winui-angle/**", "scripts/infra/native/shared/**", "scripts/infra/native/windows/**", "scripts/VERSIONS.txt"],
      "submodules": ["externals/skia", "externals/depot_tools"]
    },
    "native_nanoserver": {
      "paths": ["native/nanoserver/**", "scripts/infra/native/shared/**", "scripts/infra/native/windows/**", "scripts/VERSIONS.txt"],
      "submodules": ["externals/skia", "externals/depot_tools"]
    },
    "native_linux": {
      "paths": ["native/linux/**", "scripts/infra/native/shared/**", "scripts/infra/native/linux/**", "scripts/VERSIONS.txt"],
      "submodules": ["externals/skia", "externals/depot_tools"]
    },
    "native_linux_cross": {
      "paths": ["native/linux-clang-cross/**", "scripts/infra/native/shared/**", "scripts/infra/native/linux/**", "scripts/VERSIONS.txt"],
      "submodules": ["externals/skia", "externals/depot_tools"]
    },
    "native_linuxnodeps": {
      "paths": ["native/linuxnodeps/**", "scripts/infra/native/shared/**", "scripts/VERSIONS.txt"],
      "submodules": ["externals/skia", "externals/depot_tools"]
    },
    "native_tizen": {
      "paths": ["native/tizen/**", "scripts/infra/native/shared/**", "scripts/infra/native/tizen/**", "scripts/VERSIONS.txt"],
      "submodules": ["externals/skia", "externals/depot_tools"]
    },
    "native_wasm": {
      "paths": ["native/wasm/**", "scripts/infra/native/shared/**", "scripts/infra/native/wasm/**", "scripts/VERSIONS.txt"],
      "submodules": ["externals/skia", "externals/depot_tools"]
    },
    "managed": {
      "depends_on": ["native_android", "native_ios", "native_macos", "native_maccatalyst", "native_tvos", "native_windows", "native_winui", "native_winui_angle", "native_nanoserver", "native_linux", "native_linux_cross", "native_linuxnodeps", "native_tizen", "native_wasm"],
      "paths": ["binding/**", "source/**", "docs/**", "utils/**", "scripts/infra/managed/**", "build.cake", "nuget.config", "global.json"],
      "submodules": ["docs"]
    },
    "package": {
      "depends_on": ["managed"],
      "paths": ["scripts/infra/package/**"]
    },
    "tests": {
      "depends_on": ["managed"],
      "paths": ["tests/**", "scripts/infra/tests/**", "benchmarks/**"]
    },
    "samples": {
      "depends_on": ["managed"],
      "paths": ["samples/**"]
    },
    "api_diff": {
      "depends_on": ["package"],
      "paths": ["changelogs/**"]
    }
  },

  "ignore": [
    "_comment: Files matching these patterns trigger NO stages",
    "documentation/**",
    "images/**",
    "interactive/**",
    ".github/**",
    ".devcontainer/**",
    ".vscode/**",
    ".agents/**",
    "*.md",
    "LICENSE.*",
    "CODE-OF-CONDUCT.md",
    "CONTRIBUTING.md",
    "External-Dependency-Info.txt",
    "cgmanifest.json"
  ],

  "global": [
    "scripts/infra/native/shared/**/*",
    "scripts/VERSIONS.txt"
  ],

  "links": [
    {"files": "**/*.cake", "pattern": "^#load\\s+\"([^\"]+)\"", "resolve": "relative"},
    {"files": "**/*.yml", "pattern": "template:\\s*/scripts/([^@\\s]+)", "resolve": "prefix", "prefix": "scripts/"},
    {"files": "**/*.yml", "pattern": "target:\\s*externals-([a-z-]+)", "resolve": "prefix", "prefix": "native/", "suffix": "/build.cake"},
    {"files": "**/*.yml", "pattern": "docker:\\s*(scripts/infra/[^\\s]+)", "resolve": "root"},
    {"files": "**/*.yml", "pattern": "(?:\\./|.\\\\)?scripts[/\\\\]infra[/\\\\]([a-zA-Z0-9_./-]+\\.(?:ps1|sh))", "resolve": "prefix", "prefix": "scripts/infra/"},
    {"files": "**/Dockerfile", "siblings": true}
  ],

  "exclude": ["**/bin/**", "**/obj/**", "**/libs/**", "**/tools/**", "**/.git/**"]
}
