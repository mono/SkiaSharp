{
  "_comment": "Repository dependency graph. Maps file paths to pipeline stages.",

  "stages": {
    "native_windows": {
      "_comment": "Native builds on Windows agents: win32, winui, winui-angle, nanoserver, android(win), tizen(win)",
      "paths": [
        "native/windows/**",
        "native/winui/**",
        "native/winui-angle/**",
        "native/nanoserver/**",
        "native/android/**",
        "native/tizen/**",
        "scripts/infra/native/shared/**",
        "scripts/infra/native/windows/**",
        "scripts/infra/native/android/**",
        "scripts/infra/native/tizen/**",
        "scripts/VERSIONS.txt"
      ],
      "submodules": ["externals/skia", "externals/depot_tools"]
    },
    "native_macos": {
      "_comment": "Native builds on macOS agents: macos, ios, maccatalyst, tvos, android(mac), tizen(mac)",
      "paths": [
        "native/macos/**",
        "native/ios/**",
        "native/maccatalyst/**",
        "native/tvos/**",
        "native/android/**",
        "native/tizen/**",
        "scripts/infra/native/shared/**",
        "scripts/infra/native/apple/**",
        "scripts/infra/native/android/**",
        "scripts/infra/native/tizen/**",
        "scripts/VERSIONS.txt"
      ],
      "submodules": ["externals/skia", "externals/depot_tools"]
    },
    "native_linux": {
      "_comment": "Native builds on Linux agents: linux, linux-clang-cross, linuxnodeps",
      "paths": [
        "native/linux/**",
        "native/linux-clang-cross/**",
        "native/linuxnodeps/**",
        "scripts/infra/native/shared/**",
        "scripts/infra/native/linux/**",
        "scripts/VERSIONS.txt"
      ],
      "submodules": ["externals/skia", "externals/depot_tools"]
    },
    "native_wasm": {
      "_comment": "Native WASM builds on Linux agents",
      "paths": [
        "native/wasm/**",
        "scripts/infra/native/shared/**",
        "scripts/infra/native/wasm/**",
        "scripts/VERSIONS.txt"
      ],
      "submodules": ["externals/skia", "externals/depot_tools"]
    },
    "managed": {
      "_comment": "C# managed library build",
      "depends_on": ["native_windows", "native_macos", "native_linux", "native_wasm"],
      "paths": [
        "binding/**",
        "source/**",
        "docs/**",
        "utils/**",
        "scripts/infra/managed/**",
        "build.cake",
        "nuget.config",
        "global.json"
      ],
      "submodules": ["docs"]
    },
    "package": {
      "_comment": "NuGet package creation",
      "depends_on": ["managed"],
      "paths": [
        "scripts/infra/package/**"
      ]
    },
    "tests": {
      "_comment": "Test execution",
      "depends_on": ["managed"],
      "paths": [
        "tests/**",
        "scripts/infra/tests/**",
        "benchmarks/**"
      ]
    },
    "samples": {
      "_comment": "Sample project builds",
      "depends_on": ["managed"],
      "paths": [
        "samples/**"
      ]
    },
    "api_diff": {
      "_comment": "API diff and documentation",
      "depends_on": ["package"],
      "paths": [
        "changelogs/**"
      ]
    }
  },

  "ignore": [
    "_comment: Files matching these patterns trigger NO stages (docs-only, non-build)",
    "documentation/**",
    "images/**",
    "interactive/**",
    ".github/**",
    ".devcontainer/**",
    ".vscode/**",
    ".agents/**",
    "*.md",
    "LICENSE.*",
    "CODE-OF-CONDUCT.md",
    "CONTRIBUTING.md",
    "External-Dependency-Info.txt",
    "cgmanifest.json"
  ],

  "_comment2": "Files not matching any stage or ignore pattern trigger ALL stages (safe fallback)",

  "global": [
    "scripts/infra/native/shared/**/*",
    "scripts/VERSIONS.txt"
  ],

  "links": [
    {
      "_comment": "Cake #load directives",
      "files": "**/*.cake",
      "pattern": "^#load\\s+\"([^\"]+)\"",
      "resolve": "relative"
    },
    {
      "_comment": "YAML template references",
      "files": "**/*.yml",
      "pattern": "template:\\s*/scripts/([^@\\s]+)",
      "resolve": "prefix",
      "prefix": "scripts/"
    },
    {
      "_comment": "YAML referencing native build targets",
      "files": "**/*.yml",
      "pattern": "target:\\s*externals-([a-z-]+)",
      "resolve": "prefix",
      "prefix": "native/",
      "suffix": "/build.cake"
    },
    {
      "_comment": "YAML referencing Docker contexts",
      "files": "**/*.yml",
      "pattern": "docker:\\s*(scripts/infra/[^\\s]+)",
      "resolve": "root"
    },
    {
      "_comment": "YAML script invocations",
      "files": "**/*.yml",
      "pattern": "(?:\\./|.\\\\)?scripts[/\\\\]infra[/\\\\]([a-zA-Z0-9_./-]+\\.(?:ps1|sh))",
      "resolve": "prefix",
      "prefix": "scripts/infra/"
    },
    {
      "_comment": "Docker contexts — Dockerfile pulls in all sibling files",
      "files": "**/Dockerfile",
      "siblings": true
    }
  ],

  "exclude": [
    "**/bin/**",
    "**/obj/**",
    "**/libs/**",
    "**/tools/**",
    "**/.git/**"
  ]
}
