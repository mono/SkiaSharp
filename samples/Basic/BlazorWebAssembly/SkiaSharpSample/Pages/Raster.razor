@page "/raster"

<h1>Raster Canvas</h1>

<p>Shows basic 2D rendering using SKCanvasView (bitmap-backed).</p>

<div class="container">
    <div class="row">
        <div class="col border rounded p-2 canvas-container">

            <SKCanvasView OnPaintSurface="OnPaintSurface" IgnorePixelScaling="true" />

        </div>
    </div>
</div>

@code {
    void OnPaintSurface(SKPaintSurfaceEventArgs e)
    {
        var canvas = e.Surface.Canvas;
        var width = e.Info.Width;
        var height = e.Info.Height;

        canvas.Clear(SKColors.White);

        using var paint = new SKPaint { IsAntialias = true };
        using var font = new SKFont { Size = 20 };

        // gradient rectangle filling most of the canvas
        using var shader = SKShader.CreateLinearGradient(
            new SKPoint(40, 40),
            new SKPoint(width - 40, height - 60),
            new[] { SKColors.Blue, SKColors.Green },
            SKShaderTileMode.Clamp);
        paint.Shader = shader;
        paint.Style = SKPaintStyle.Fill;
        canvas.DrawRect(new SKRect(40, 40, width - 40, height - 60), paint);
        paint.Shader = null;

        // filled red circle
        paint.Color = SKColors.Red;
        paint.Style = SKPaintStyle.Fill;
        canvas.DrawCircle(width / 2f, height / 2f - 30, 50, paint);

        // stroked yellow rectangle
        paint.Color = SKColors.Yellow;
        paint.Style = SKPaintStyle.Stroke;
        paint.StrokeWidth = 3;
        canvas.DrawRect(new SKRect(80, 80, width - 80, height - 100), paint);

        // thick orange line
        paint.Color = SKColors.Orange;
        paint.StrokeWidth = 6;
        canvas.DrawLine(60, 60, width - 60, height - 80, paint);

        // centered text near the bottom
        paint.Style = SKPaintStyle.Fill;
        paint.Color = SKColors.Black;
        canvas.DrawText("Hello, SkiaSharp!", width / 2f, height - 30, SKTextAlign.Center, font, paint);
    }
}
