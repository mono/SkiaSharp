@page "/"

<h1>SkiaSharp</h1>

<p>SkiaSharp is a cross-platform 2D graphics API for .NET platforms based on Google's Skia Graphics Library, providing comprehensive 2D rendering across mobile, server, and desktop.</p>

<div class="container">
    <div class="row">
        <div class="col border rounded p-2 canvas-container">

            <SKCanvasView OnPaintSurface="OnPaintSurface" IgnorePixelScaling="true" />

        </div>
    </div>
    <div class="row mt-4">
        <div class="col">
            <h4>Feature Overview</h4>
            <ul>
                <li><a href="/raster"><strong>Raster</strong></a> — Basic 2D rendering with SKCanvasView</li>
                <li><a href="/gpu"><strong>GPU</strong></a> — Animated rendering with SKGLView</li>
                <li><a href="/drawing"><strong>Drawing</strong></a> — Interactive drawing with touch &amp; wheel input</li>
            </ul>
        </div>
    </div>
</div>

@code {

    void OnPaintSurface(SKPaintSurfaceEventArgs e)
    {
        var canvas = e.Surface.Canvas;
        var width = e.Info.Width;
        var height = e.Info.Height;
        var center = new SKPoint(width / 2f, height / 2f);
        var radius = Math.Max(width, height) / 2f;

        canvas.Clear(SKColors.White);

        // radial gradient background
        using var bgPaint = new SKPaint { IsAntialias = true };
        using var bgShader = SKShader.CreateRadialGradient(
            center, radius,
            new[] { new SKColor(0x44, 0x88, 0xFF), new SKColor(0x88, 0x33, 0xCC) },
            SKShaderTileMode.Clamp);
        bgPaint.Shader = bgShader;
        canvas.DrawRect(0, 0, width, height, bgPaint);

        // scattered colored circles
        using var circlePaint = new SKPaint { IsAntialias = true, Style = SKPaintStyle.Fill };
        var circles = new (float xf, float yf, float rf, SKColor color)[]
        {
            (0.2f, 0.3f, 0.10f, new SKColor(0xFF, 0x6B, 0x6B, 0x99)),
            (0.75f, 0.25f, 0.08f, new SKColor(0x4E, 0xCD, 0xC4, 0x99)),
            (0.15f, 0.7f, 0.07f, new SKColor(0xFF, 0xE6, 0x6D, 0xBB)),
            (0.8f, 0.7f, 0.12f, new SKColor(0xA2, 0x9B, 0xFE, 0x99)),
            (0.5f, 0.15f, 0.06f, new SKColor(0xFF, 0x92, 0x4C, 0xAA)),
            (0.4f, 0.8f, 0.09f, new SKColor(0x6C, 0xE8, 0x8A, 0x99)),
        };
        foreach (var (xf, yf, rf, color) in circles)
        {
            circlePaint.Color = color;
            canvas.DrawCircle(xf * width, yf * height, rf * Math.Min(width, height), circlePaint);
        }

        // centered "SkiaSharp" text
        using var textPaint = new SKPaint
        {
            Color = SKColors.White,
            IsAntialias = true,
            Style = SKPaintStyle.Fill
        };
        using var font = new SKFont { Size = 48 };
        canvas.DrawText("SkiaSharp", center.X, center.Y + font.Size / 3f, SKTextAlign.Center, font, textPaint);
    }

}
