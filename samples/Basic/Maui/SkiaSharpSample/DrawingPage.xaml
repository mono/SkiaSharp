<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:skia="clr-namespace:SkiaSharp.Views.Maui.Controls;assembly=SkiaSharp.Views.Maui.Controls"
             x:Class="SkiaSharpSample.DrawingPage"
             Title="Drawing">

    <Grid>
        <skia:SKCanvasView x:Name="skiaView"
                           PaintSurface="OnPaintSurface"
                           EnableTouchEvents="True"
                           Touch="OnTouch" />

        <!-- Floating Clear button — top-right -->
        <Button Text="Clear"
                Clicked="OnClearClicked"
                HorizontalOptions="End"
                VerticalOptions="Start"
                Margin="0,12,12,0"
                BackgroundColor="#CC1E1E1E"
                TextColor="White"
                CornerRadius="16"
                HeightRequest="34"
                Padding="16,0"
                FontSize="13" />

        <!-- Floating toolbox — bottom-center overlay -->
        <Border HorizontalOptions="Center"
                VerticalOptions="End"
                Margin="0,0,0,16"
                StrokeShape="RoundRectangle 24"
                Stroke="Transparent"
                BackgroundColor="#CC1E1E1E"
                Padding="20,14"
                InputTransparent="False">
            <StackLayout Spacing="12">
                <StackLayout.Orientation>
                    <OnIdiom x:TypeArguments="StackOrientation"
                             Phone="Vertical"
                             Default="Horizontal" />
                </StackLayout.Orientation>

                <!-- Color swatches -->
                <FlexLayout Direction="Row" JustifyContent="Center" Wrap="NoWrap" AlignItems="Center">
                    <Button BackgroundColor="#000000" WidthRequest="36" HeightRequest="36" CornerRadius="18"
                            Clicked="OnColorClicked" Margin="0,0,8,0" BorderWidth="0" Padding="0" />
                    <Button BackgroundColor="#E53935" WidthRequest="36" HeightRequest="36" CornerRadius="18"
                            Clicked="OnColorClicked" Margin="0,0,8,0" BorderWidth="0" Padding="0" />
                    <Button BackgroundColor="#1E88E5" WidthRequest="36" HeightRequest="36" CornerRadius="18"
                            Clicked="OnColorClicked" Margin="0,0,8,0" BorderWidth="0" Padding="0" />
                    <Button BackgroundColor="#43A047" WidthRequest="36" HeightRequest="36" CornerRadius="18"
                            Clicked="OnColorClicked" Margin="0,0,8,0" BorderWidth="0" Padding="0" />
                    <Button BackgroundColor="#FB8C00" WidthRequest="36" HeightRequest="36" CornerRadius="18"
                            Clicked="OnColorClicked" Margin="0,0,8,0" BorderWidth="0" Padding="0" />
                    <Button BackgroundColor="#8E24AA" WidthRequest="36" HeightRequest="36" CornerRadius="18"
                            Clicked="OnColorClicked" BorderWidth="0" Padding="0" />
                </FlexLayout>

                <!-- Brush size slider + label -->
                <StackLayout Orientation="Horizontal" HorizontalOptions="Center" Spacing="8"
                             VerticalOptions="Center">
                    <Slider x:Name="brushSlider"
                            Minimum="1" Maximum="50" Value="4"
                            WidthRequest="160"
                            MinimumTrackColor="White"
                            MaximumTrackColor="#66FFFFFF"
                            ThumbColor="White"
                            VerticalOptions="Center"
                            ValueChanged="OnSliderValueChanged" />
                    <Label x:Name="brushLabel" Text="4"
                           TextColor="White" FontSize="13"
                           VerticalOptions="Center"
                           WidthRequest="24" />
                </StackLayout>
            </StackLayout>
        </Border>
    </Grid>

</ContentPage>
