<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:skia="clr-namespace:SkiaSharp.Views.Maui.Controls;assembly=SkiaSharp.Views.Maui.Controls"
             x:Class="SkiaSharpSample.DrawingPage"
             Title="Drawing">

    <Grid>
        <skia:SKCanvasView x:Name="skiaView"
                           PaintSurface="OnPaintSurface"
                           EnableTouchEvents="True"
                           Touch="OnTouch" />

        <!-- Floating Clear button — top-right -->
        <Button Text="Clear"
                Clicked="OnClearClicked"
                HorizontalOptions="End"
                VerticalOptions="Start"
                Margin="0,12,12,0"
                BackgroundColor="#CC1E1E1E"
                TextColor="White"
                CornerRadius="16"
                HeightRequest="34"
                Padding="16,0"
                FontSize="13" />

        <!-- Floating toolbox — bottom-center overlay -->
        <Border x:Name="toolboxBorder"
                HorizontalOptions="Center"
                VerticalOptions="End"
                Margin="0,0,0,16"
                StrokeShape="RoundRectangle 24"
                Stroke="#44FFFFFF"
                StrokeThickness="1"
                BackgroundColor="#CC1E1E1E"
                Padding="16,12"
                InputTransparent="False">
            <StackLayout Orientation="{OnIdiom Phone=Vertical, Default=Horizontal}" Spacing="12">

                <!-- Color swatches -->
                <FlexLayout x:Name="swatchContainer" Direction="Row" JustifyContent="Center" Wrap="NoWrap" AlignItems="Center">
                    <Border StyleClass="swatch" StrokeShape="RoundRectangle 20" Padding="0" BackgroundColor="Transparent"
                            Stroke="{x:Static Colors.DodgerBlue}" StrokeThickness="3" WidthRequest="40" HeightRequest="40">
                        <Button BackgroundColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}"
                                WidthRequest="34" HeightRequest="34" CornerRadius="17"
                                Clicked="OnColorClicked" BorderWidth="0" Padding="0"
                                HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>
                    <Border StyleClass="swatch" StrokeShape="RoundRectangle 20" Padding="0" BackgroundColor="Transparent"
                            Stroke="Transparent" StrokeThickness="3" WidthRequest="40" HeightRequest="40" Margin="6,0,0,0">
                        <Button BackgroundColor="{AppThemeBinding Light=#E53935, Dark=#EF5350}"
                                WidthRequest="34" HeightRequest="34" CornerRadius="17"
                                Clicked="OnColorClicked" BorderWidth="0" Padding="0"
                                HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>
                    <Border StyleClass="swatch" StrokeShape="RoundRectangle 20" Padding="0" BackgroundColor="Transparent"
                            Stroke="Transparent" StrokeThickness="3" WidthRequest="40" HeightRequest="40" Margin="6,0,0,0">
                        <Button BackgroundColor="{AppThemeBinding Light=#1E88E5, Dark=#42A5F5}"
                                WidthRequest="34" HeightRequest="34" CornerRadius="17"
                                Clicked="OnColorClicked" BorderWidth="0" Padding="0"
                                HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>
                    <Border StyleClass="swatch" StrokeShape="RoundRectangle 20" Padding="0" BackgroundColor="Transparent"
                            Stroke="Transparent" StrokeThickness="3" WidthRequest="40" HeightRequest="40" Margin="6,0,0,0">
                        <Button BackgroundColor="{AppThemeBinding Light=#43A047, Dark=#66BB6A}"
                                WidthRequest="34" HeightRequest="34" CornerRadius="17"
                                Clicked="OnColorClicked" BorderWidth="0" Padding="0"
                                HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>
                    <Border StyleClass="swatch" StrokeShape="RoundRectangle 20" Padding="0" BackgroundColor="Transparent"
                            Stroke="Transparent" StrokeThickness="3" WidthRequest="40" HeightRequest="40" Margin="6,0,0,0">
                        <Button BackgroundColor="{AppThemeBinding Light=#FB8C00, Dark=#FFA726}"
                                WidthRequest="34" HeightRequest="34" CornerRadius="17"
                                Clicked="OnColorClicked" BorderWidth="0" Padding="0"
                                HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>
                    <Border StyleClass="swatch" StrokeShape="RoundRectangle 20" Padding="0" BackgroundColor="Transparent"
                            Stroke="Transparent" StrokeThickness="3" WidthRequest="40" HeightRequest="40" Margin="6,0,0,0">
                        <Button BackgroundColor="{AppThemeBinding Light=#8E24AA, Dark=#AB47BC}"
                                WidthRequest="34" HeightRequest="34" CornerRadius="17"
                                Clicked="OnColorClicked" BorderWidth="0" Padding="0"
                                HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>
                </FlexLayout>

                <!-- Brush size slider + label -->
                <StackLayout Orientation="Horizontal" HorizontalOptions="Center" Spacing="8"
                             VerticalOptions="Center">
                    <Slider x:Name="brushSlider"
                            Minimum="1" Maximum="50" Value="4"
                            WidthRequest="160"
                            MinimumTrackColor="White"
                            MaximumTrackColor="#66FFFFFF"
                            ThumbColor="White"
                            VerticalOptions="Center"
                            ValueChanged="OnSliderValueChanged" />
                    <Label x:Name="brushLabel" Text="4"
                           TextColor="White" FontSize="13"
                           VerticalOptions="Center"
                           WidthRequest="24" />
                </StackLayout>
            </StackLayout>
        </Border>
    </Grid>

</ContentPage>
