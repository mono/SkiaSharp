<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:local="clr-namespace:SkiaSharpSample"
       x:Class="SkiaSharpSample.AppShell"
       FlyoutBehavior="Flyout">

    <FlyoutItem Title="CPU Canvas" Icon="">
        <ShellContent ContentTemplate="{DataTemplate local:CpuPage}" />
    </FlyoutItem>

    <FlyoutItem Title="GPU" Icon="">
        <ShellContent ContentTemplate="{DataTemplate local:GpuPage}" />
    </FlyoutItem>

    <FlyoutItem Title="Drawing" Icon="">
        <ShellContent ContentTemplate="{DataTemplate local:DrawingPage}" />
    </FlyoutItem>

</Shell>
