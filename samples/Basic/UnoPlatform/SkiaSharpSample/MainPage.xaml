<Page
    x:Class="SkiaSharpSample.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SkiaSharpSample">

    <NavigationView x:Name="NavView"
                    IsBackButtonVisible="Collapsed"
                    SelectionChanged="NavView_SelectionChanged"
                    PaneDisplayMode="Left">
        <NavigationView.MenuItems>
            <NavigationViewItem Content="CPU Canvas" Tag="cpu" />
            <NavigationViewItem Content="GPU (ANGLE)" Tag="gpu" />
            <NavigationViewItem Content="Drawing" Tag="drawing" />
        </NavigationView.MenuItems>
        <Frame x:Name="ContentFrame" />
    </NavigationView>

</Page>