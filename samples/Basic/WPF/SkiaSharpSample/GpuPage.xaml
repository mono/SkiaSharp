<UserControl x:Class="SkiaSharpSample.GpuPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:skia="clr-namespace:SkiaSharp.Views.WPF;assembly=SkiaSharp.Views.WPF"
             Loaded="OnLoaded" Unloaded="OnUnloaded">
    <Grid>
        <skia:SKGLElement x:Name="GlView" PaintSurface="OnPaintSurface" />
        <TextBlock x:Name="FpsText" Text="FPS: --"
                   Foreground="White" FontSize="14" FontFamily="Consolas"
                   HorizontalAlignment="Right" VerticalAlignment="Top"
                   Margin="0,8,12,0"
                   IsHitTestVisible="False">
            <TextBlock.Effect>
                <DropShadowEffect ShadowDepth="1" BlurRadius="3" Color="Black" Opacity="0.8" />
            </TextBlock.Effect>
        </TextBlock>
    </Grid>
</UserControl>
