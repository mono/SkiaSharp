<UserControl x:Class="SkiaSharpSample.DrawingPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:skia="clr-namespace:SkiaSharp.Views.WPF;assembly=SkiaSharp.Views.WPF">
    <Grid>
        <!-- Canvas fills everything -->
        <Border x:Name="CanvasBorder" Background="Transparent">
            <skia:SKElement x:Name="SkCanvas" PaintSurface="OnPaintSurface" IgnorePixelScaling="True" />
        </Border>

        <!-- Clear button top-right -->
        <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,12,12,0" CornerRadius="16"
                Background="#CC1E1E1E">
            <Button Content="Clear" Click="OnClear"
                    Padding="16,6"
                    Foreground="White" FontWeight="SemiBold"
                    Background="Transparent" BorderThickness="0"
                    Cursor="Hand" />
        </Border>

        <!-- Floating toolbox bottom-center -->
        <Border HorizontalAlignment="Center" VerticalAlignment="Bottom"
                Margin="0,0,0,16" CornerRadius="24"
                BorderBrush="#44FFFFFF" BorderThickness="1"
                Padding="16,12"
                Background="#CC1E1E1E">
            <WrapPanel x:Name="ToolboxPanel" Orientation="Horizontal">
                <!-- Color swatches -->
                <StackPanel x:Name="SwatchPanel" Orientation="Horizontal" Margin="0,0,8,0">
                    <Border x:Name="ColorBlack" Width="36" Height="36" CornerRadius="18"
                            BorderBrush="DodgerBlue" BorderThickness="3"
                            Margin="4,0" Cursor="Hand" MouseDown="OnColorPick" Tag="Black" />
                    <Border x:Name="ColorRed" Width="36" Height="36" CornerRadius="18"
                            BorderBrush="Transparent" BorderThickness="3"
                            Margin="4,0" Cursor="Hand" MouseDown="OnColorPick" Tag="Red" />
                    <Border x:Name="ColorBlue" Width="36" Height="36" CornerRadius="18"
                            BorderBrush="Transparent" BorderThickness="3"
                            Margin="4,0" Cursor="Hand" MouseDown="OnColorPick" Tag="Blue" />
                    <Border x:Name="ColorGreen" Width="36" Height="36" CornerRadius="18"
                            BorderBrush="Transparent" BorderThickness="3"
                            Margin="4,0" Cursor="Hand" MouseDown="OnColorPick" Tag="Green" />
                    <Border x:Name="ColorOrange" Width="36" Height="36" CornerRadius="18"
                            BorderBrush="Transparent" BorderThickness="3"
                            Margin="4,0" Cursor="Hand" MouseDown="OnColorPick" Tag="Orange" />
                    <Border x:Name="ColorPurple" Width="36" Height="36" CornerRadius="18"
                            BorderBrush="Transparent" BorderThickness="3"
                            Margin="4,0" Cursor="Hand" MouseDown="OnColorPick" Tag="Purple" />
                </StackPanel>

                <!-- Brush size slider + label -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                    <Slider x:Name="BrushSlider" Minimum="1" Maximum="50" Value="4"
                            Width="140" VerticalAlignment="Center"
                            ValueChanged="OnBrushSizeChanged" />
                    <TextBlock x:Name="BrushSizeText" Text="4"
                               Foreground="White" VerticalAlignment="Center"
                               FontSize="13" Margin="8,0,0,0" Width="24" />
                </StackPanel>
            </WrapPanel>
        </Border>
    </Grid>
</UserControl>
