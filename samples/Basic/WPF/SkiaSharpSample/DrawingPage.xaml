<UserControl x:Class="SkiaSharpSample.DrawingPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:skia="clr-namespace:SkiaSharp.Views.WPF;assembly=SkiaSharp.Views.WPF">
    <DockPanel>
        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Background="#F0F0F0" Padding="8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Color:" VerticalAlignment="Center" Margin="0,0,8,0" />

                <Border x:Name="ColorBlack" Width="28" Height="28" Background="Black"
                        BorderBrush="#007ACC" BorderThickness="2" CornerRadius="4"
                        Margin="2" Cursor="Hand" MouseDown="OnColorPick" Tag="Black" />
                <Border x:Name="ColorRed" Width="28" Height="28" Background="#E53935"
                        BorderBrush="Transparent" BorderThickness="2" CornerRadius="4"
                        Margin="2" Cursor="Hand" MouseDown="OnColorPick" Tag="Red" />
                <Border x:Name="ColorBlue" Width="28" Height="28" Background="#1E88E5"
                        BorderBrush="Transparent" BorderThickness="2" CornerRadius="4"
                        Margin="2" Cursor="Hand" MouseDown="OnColorPick" Tag="Blue" />
                <Border x:Name="ColorGreen" Width="28" Height="28" Background="#43A047"
                        BorderBrush="Transparent" BorderThickness="2" CornerRadius="4"
                        Margin="2" Cursor="Hand" MouseDown="OnColorPick" Tag="Green" />
                <Border x:Name="ColorOrange" Width="28" Height="28" Background="#FB8C00"
                        BorderBrush="Transparent" BorderThickness="2" CornerRadius="4"
                        Margin="2" Cursor="Hand" MouseDown="OnColorPick" Tag="Orange" />
                <Border x:Name="ColorPurple" Width="28" Height="28" Background="#8E24AA"
                        BorderBrush="Transparent" BorderThickness="2" CornerRadius="4"
                        Margin="2" Cursor="Hand" MouseDown="OnColorPick" Tag="Purple" />

                <Border Width="1" Background="#CCCCCC" Margin="12,2" />

                <TextBlock x:Name="BrushSizeText" Text="Brush: 4px"
                           VerticalAlignment="Center" Margin="4,0,12,0" />

                <Button Content="Clear" Padding="12,4" Click="OnClear" />

                <TextBlock Text="(scroll to change brush size)" VerticalAlignment="Center"
                           Foreground="#888888" FontSize="11" Margin="12,0,0,0" />
            </StackPanel>
        </Border>

        <!-- Canvas -->
        <Grid>
            <skia:SKElement x:Name="SkCanvas" PaintSurface="OnPaintSurface" IgnorePixelScaling="True" />
        </Grid>
    </DockPanel>
</UserControl>
