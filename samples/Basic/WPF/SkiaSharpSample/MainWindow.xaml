<Window x:Class="SkiaSharpSample.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SkiaSharpSample"
        mc:Ignorable="d"
        Title="SkiaSharp Sample" Height="600" Width="900" Icon="/icon.ico">

    <TabControl x:Name="TabNav" SelectionChanged="OnTabSelectionChanged">
        <TabItem Header="CPU" Tag="cpu" />
        <TabItem Header="GPU" Tag="gpu" />
        <TabItem Header="Drawing" Tag="drawing" />
    </TabControl>

</Window>
