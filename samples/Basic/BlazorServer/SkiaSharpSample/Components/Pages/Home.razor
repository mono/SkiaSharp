@page "/"
@rendermode InteractiveServer

<PageTitle>SkiaSharp on Blazor Server</PageTitle>

<h1>SkiaSharp on Blazor Server</h1>

<p>
    This canvas is drawn with SkiaSharp <strong>on the server</strong>. Each frame is
    rendered with the .NET SkiaSharp runtime, encoded, and streamed to the browser over the
    Blazor Server (SignalR) circuit. Move the mouse over the canvas to interact.
</p>

<div style="width: 480px; height: 320px; border: 1px solid #bbb; border-radius: 8px; overflow: hidden;">
    <SKCanvasView OnPaintSurface="OnPaintSurface"
                  EnableRenderLoop="true"
                  style="width: 100%; height: 100%; touch-action: none; display: block;"
                  @onpointermove="OnPointerMove" />
</div>

<p style="margin-top: 1rem; color: #666;">
    Rendered @frameCount frame(s). Transfer format defaults to JPEG for Server (configurable).
</p>

@code {
    private int frameCount;
    private float pointerX = 240;
    private float pointerY = 160;

    private void OnPointerMove(PointerEventArgs e)
    {
        // OffsetX/Y are CSS pixels; good enough for a demo (see docs for exact mapping).
        pointerX = (float)e.OffsetX;
        pointerY = (float)e.OffsetY;
    }

    private void OnPaintSurface(SKPaintSurfaceEventArgs e)
    {
        frameCount++;

        var canvas = e.Surface.Canvas;
        var info = e.Info;

        canvas.Clear(new SKColor(0x1E, 0x1E, 0x2E));

        var t = frameCount * 0.05f;
        var scale = info.Width / 480f;

        // orbiting circle
        var cx = info.Width / 2f + MathF.Sin(t) * 120 * scale;
        var cy = info.Height / 2f + MathF.Cos(t * 0.8f) * 80 * scale;
        using (var paint = new SKPaint { Color = new SKColor(0x89, 0xB4, 0xFA), IsAntialias = true })
            canvas.DrawCircle(cx, cy, 36 * scale, paint);

        // pointer marker (map CSS pointer coords into device pixels)
        var px = pointerX * scale;
        var py = pointerY * scale;
        using (var paint = new SKPaint { Color = new SKColor(0xF3, 0x8B, 0xA8), IsAntialias = true, Style = SKPaintStyle.Stroke, StrokeWidth = 3 * scale })
            canvas.DrawCircle(px, py, 18 * scale, paint);

        using var font = new SKFont { Size = 20 * scale };
        using var textPaint = new SKPaint { Color = SKColors.White, IsAntialias = true };
        canvas.DrawText($"frame {frameCount}", 12 * scale, 30 * scale, SKTextAlign.Left, font, textPaint);
    }
}
