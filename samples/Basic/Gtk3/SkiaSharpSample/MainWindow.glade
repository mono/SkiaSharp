<?xml version="1.0" encoding="UTF-8"?>
<!-- GtkBuilder UI definition for SkiaSharp GTK3 Sample.
     SKDrawingArea widgets are added in code since Glade does not know about
     custom SkiaSharp types; placeholder GtkBox containers are used instead. -->
<interface>
  <requires lib="gtk+" version="3.20"/>
  <object class="GtkBox" id="rootBox">
    <property name="visible">True</property>
    <property name="can-focus">False</property>
    <property name="orientation">horizontal</property>
    <child>
      <object class="GtkStackSidebar" id="sidebar">
        <property name="visible">True</property>
        <property name="can-focus">False</property>
        <property name="width-request">200</property>
        <property name="stack">contentStack</property>
      </object>
      <packing>
        <property name="expand">False</property>
        <property name="fill">True</property>
        <property name="position">0</property>
      </packing>
    </child>
    <child>
      <object class="GtkStack" id="contentStack">
        <property name="visible">True</property>
        <property name="can-focus">False</property>
        <property name="transition-type">crossfade</property>
        <property name="transition-duration">300</property>
        <!-- CPU Canvas page — SKDrawingArea inserted in code -->
        <child>
          <object class="GtkBox" id="cpuPage">
            <property name="visible">True</property>
            <property name="can-focus">False</property>
          </object>
          <packing>
            <property name="name">cpu</property>
            <property name="title">CPU Canvas</property>
          </packing>
        </child>
        <!-- Drawing page -->
        <child>
          <object class="GtkBox" id="drawingPage">
            <property name="visible">True</property>
            <property name="can-focus">False</property>
            <property name="orientation">vertical</property>
            <!-- Canvas area — SKDrawingArea inserted in code -->
            <child>
              <object class="GtkBox" id="drawingCanvasContainer">
                <property name="visible">True</property>
                <property name="can-focus">False</property>
              </object>
              <packing>
                <property name="expand">True</property>
                <property name="fill">True</property>
                <property name="position">0</property>
              </packing>
            </child>
            <!-- Toolbar with color and clear buttons -->
            <child>
              <object class="GtkBox" id="drawingToolbar">
                <property name="visible">True</property>
                <property name="can-focus">False</property>
                <property name="orientation">horizontal</property>
                <property name="spacing">4</property>
                <property name="height-request">40</property>
                <child>
                  <object class="GtkButton" id="btnBlack">
                    <property name="label">Black</property>
                    <property name="visible">True</property>
                    <property name="can-focus">True</property>
                  </object>
                  <packing>
                    <property name="expand">False</property>
                    <property name="fill">True</property>
                    <property name="padding">2</property>
                    <property name="position">0</property>
                  </packing>
                </child>
                <child>
                  <object class="GtkButton" id="btnRed">
                    <property name="label">Red</property>
                    <property name="visible">True</property>
                    <property name="can-focus">True</property>
                  </object>
                  <packing>
                    <property name="expand">False</property>
                    <property name="fill">True</property>
                    <property name="padding">2</property>
                    <property name="position">1</property>
                  </packing>
                </child>
                <child>
                  <object class="GtkButton" id="btnBlue">
                    <property name="label">Blue</property>
                    <property name="visible">True</property>
                    <property name="can-focus">True</property>
                  </object>
                  <packing>
                    <property name="expand">False</property>
                    <property name="fill">True</property>
                    <property name="padding">2</property>
                    <property name="position">2</property>
                  </packing>
                </child>
                <child>
                  <object class="GtkButton" id="btnGreen">
                    <property name="label">Green</property>
                    <property name="visible">True</property>
                    <property name="can-focus">True</property>
                  </object>
                  <packing>
                    <property name="expand">False</property>
                    <property name="fill">True</property>
                    <property name="padding">2</property>
                    <property name="position">3</property>
                  </packing>
                </child>
                <child>
                  <object class="GtkButton" id="btnOrange">
                    <property name="label">Orange</property>
                    <property name="visible">True</property>
                    <property name="can-focus">True</property>
                  </object>
                  <packing>
                    <property name="expand">False</property>
                    <property name="fill">True</property>
                    <property name="padding">2</property>
                    <property name="position">4</property>
                  </packing>
                </child>
                <child>
                  <object class="GtkButton" id="btnPurple">
                    <property name="label">Purple</property>
                    <property name="visible">True</property>
                    <property name="can-focus">True</property>
                  </object>
                  <packing>
                    <property name="expand">False</property>
                    <property name="fill">True</property>
                    <property name="padding">2</property>
                    <property name="position">5</property>
                  </packing>
                </child>
                <child>
                  <object class="GtkButton" id="btnClear">
                    <property name="label">Clear</property>
                    <property name="visible">True</property>
                    <property name="can-focus">True</property>
                  </object>
                  <packing>
                    <property name="expand">False</property>
                    <property name="fill">True</property>
                    <property name="padding">2</property>
                    <property name="position">6</property>
                  </packing>
                </child>
                <child>
                  <object class="GtkLabel" id="brushSizeLabel">
                    <property name="visible">True</property>
                    <property name="can-focus">False</property>
                    <property name="label">Brush: 4px</property>
                  </object>
                  <packing>
                    <property name="expand">False</property>
                    <property name="fill">True</property>
                    <property name="padding">6</property>
                    <property name="position">7</property>
                  </packing>
                </child>
              </object>
              <packing>
                <property name="expand">False</property>
                <property name="fill">True</property>
                <property name="padding">4</property>
                <property name="position">1</property>
              </packing>
            </child>
          </object>
          <packing>
            <property name="name">drawing</property>
            <property name="title">Drawing</property>
          </packing>
        </child>
      </object>
      <packing>
        <property name="expand">True</property>
        <property name="fill">True</property>
        <property name="position">1</property>
      </packing>
    </child>
  </object>
</interface>
