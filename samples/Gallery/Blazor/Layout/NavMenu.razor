<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">SkiaSharp Gallery</a>
        <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div class="@NavMenuCssClass nav-scrollable" @onclick="ToggleNavMenu">
    <nav class="nav flex-column">

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <input class="form-control form-control-sm mt-2 mb-1" type="search"
                   placeholder="Search samples…"
                   @bind="searchText"
                   @bind:event="oninput"
                   @onclick:stopPropagation="true" />
        </div>

        @foreach (var group in GetFilteredGroups())
        {
            <div class="px-3 pt-2">
                <small class="text-uppercase fw-bold" style="color: rgba(255,255,255,0.5); font-size: 0.65rem; letter-spacing: 0.08em;">@group.Key</small>
            </div>
            @foreach (var sample in group.OrderBy(s => s.Title))
            {
                <div class="nav-item px-3">
                    <NavLink class="nav-link" style="font-size: 0.85rem; padding-top: 0.25rem; padding-bottom: 0.25rem;"
                             href="@($"sample/{Uri.EscapeDataString(sample.Title)}")">
                        @sample.Title
                    </NavLink>
                </div>
            }
        }

    </nav>
</div>

@code {
    private bool collapseNavMenu = true;
    private string searchText = string.Empty;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

    private IEnumerable<IGrouping<string, SampleBase>> GetFilteredGroups()
    {
        var samples = SamplesManager.GetSamples();
        var filtered = samples.Where(s => s.MatchesFilter(searchText));

        return filtered
            .GroupBy(s => s.Category)
            .OrderBy(g => g.Key == SampleCategories.Showcases ? "" : g.Key);
    }
}
