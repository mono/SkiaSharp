@page "/sample/{sampleTitle}"
@implements IDisposable
@inject IJSRuntime JS

<PageTitle>@(sample?.Title ?? "Sample") — SkiaSharp Gallery</PageTitle>

@if (sample is null)
{
    <div class="alert alert-warning">
        Sample "<strong>@SampleTitle</strong>" was not found.
        <a href="">Return to home</a>
    </div>
}
else
{
    <h2>@sample.Title</h2>

    @if (!string.IsNullOrWhiteSpace(sample.Description))
    {
        <p class="text-muted">@sample.Description</p>
    }

    @if (sample is not DocumentSampleBase)
    {
        <div class="canvas-wrapper border rounded mb-3">
            @if (UseGpu)
            {
                <SKGLView @ref="glView"
                          OnPaintSurface="OnPaintGL"
                          EnableRenderLoop="@(sample is AnimatedSampleBase or AnimatedInteractiveSampleBase)"
                          style="width:100%;height:60vh;min-height:300px;display:block;" />
            }
            else
            {
                <SKCanvasView @ref="canvasView"
                              OnPaintSurface="OnPaintRaster"
                              style="width:100%;height:60vh;min-height:300px;display:block;"
                              @onpointerdown="OnPointerDown"
                              @onpointermove="OnPointerMove"
                              @onpointerup="OnPointerUp"
                              @onclick="OnClick" />
            }
        </div>
    }

    @if (sample is InteractiveSampleBase interactive)
    {
        <ControlPanel Controls="@interactive.Controls"
                      OnChanged="@OnControlChanged" />
    }

    @if (sample is DocumentSampleBase && !string.IsNullOrEmpty(documentBlobUrl))
    {
        <div class="border rounded mt-2" style="height:60vh;min-height:400px;">
            <iframe src="@documentBlobUrl" style="width:100%;height:100%;border:none;" />
        </div>
    }
}

@code {
    [Parameter]
    public string? SampleTitle { get; set; }

    [CascadingParameter(Name = "UseGpu")]
    public bool UseGpu { get; set; }

    private SampleBase? sample;
    private SKCanvasView? canvasView;
    private SKGLView? glView;
    private bool previousUseGpu;
    private string? documentBlobUrl;

    private SKPoint? lastPointerDown;
    private SKPoint panStartPoint;

    protected override void OnParametersSet()
    {
        // Sample changed
        var title = Uri.UnescapeDataString(SampleTitle ?? string.Empty);
        var newSample = SamplesManager.GetSample(title);
        if (newSample != sample || previousUseGpu != UseGpu)
        {
            if (newSample != sample)
            {
                DisposeSample();
                sample = newSample;

                if (sample is not null)
                {
                    sample.RefreshRequested += OnRefreshRequested;
                    sample.Init();
                    GenerateDocumentIfNeeded();
                }
            }

            previousUseGpu = UseGpu;

            // Force re-render then invalidate the newly mounted view
            InvokeAsync(async () =>
            {
                StateHasChanged();
                await Task.Yield();
                canvasView?.Invalidate();
                glView?.Invalidate();
            });
        }
    }

    private void OnRefreshRequested(object? sender, EventArgs e)
    {
        if (!UseGpu)
            canvasView?.Invalidate();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender || glView is not null)
        {
            await Task.Yield();
            glView?.Invalidate();
            canvasView?.Invalidate();
        }
    }

    private void OnPaintRaster(SKPaintSurfaceEventArgs e)
    {
        e.Surface.Canvas.Clear(SKColors.White);
        sample?.DrawSample(e.Surface.Canvas, e.Info.Width, e.Info.Height);
        UpdateDocumentPreview();
    }

    private void OnPaintGL(SKPaintGLSurfaceEventArgs e)
    {
        e.Surface.Canvas.Clear(SKColors.White);
        sample?.DrawSample(e.Surface.Canvas, e.BackendRenderTarget.Width, e.BackendRenderTarget.Height);
        UpdateDocumentPreview();
    }

    private void UpdateDocumentPreview()
    {
        if (sample is not DocumentSampleBase doc || doc.DocumentBytes is not { Length: > 0 })
            return;
        if (!string.IsNullOrEmpty(documentBlobUrl))
            return; // already created

        var mime = doc.DocumentMimeType ?? "application/pdf";
        var bytes = doc.DocumentBytes;
        InvokeAsync(async () =>
        {
            documentBlobUrl = await JS.InvokeAsync<string>(
                "eval",
                "((bytes, mime) => URL.createObjectURL(new Blob([bytes], {type: mime})))"
                    + $"(new Uint8Array({System.Text.Json.JsonSerializer.Serialize(bytes)}), '{mime}')");
            StateHasChanged();
        });
    }

    private void OnPointerDown(PointerEventArgs e)
    {
        lastPointerDown = new SKPoint((float)e.OffsetX, (float)e.OffsetY);
        panStartPoint = lastPointerDown.Value;
        sample?.Pan(GestureState.Started, panStartPoint);
    }

    private void OnPointerMove(PointerEventArgs e)
    {
        if (lastPointerDown is null) return;
        var current = new SKPoint((float)e.OffsetX, (float)e.OffsetY);
        sample?.Pan(GestureState.Running, current - panStartPoint);
        canvasView?.Invalidate();
    }

    private void OnPointerUp(PointerEventArgs e)
    {
        if (lastPointerDown is not null)
        {
            sample?.Pan(GestureState.Completed, SKPoint.Empty);
            lastPointerDown = null;
        }
        canvasView?.Invalidate();
    }

    private void OnClick(MouseEventArgs e)
    {
        sample?.Tap();
        canvasView?.Invalidate();
    }

    private void DisposeSample()
    {
        if (sample is not null)
        {
            sample.RefreshRequested -= OnRefreshRequested;
            sample.Destroy();
            sample = null;
        }

        if (!string.IsNullOrEmpty(documentBlobUrl))
        {
            _ = JS.InvokeVoidAsync("eval", $"URL.revokeObjectURL('{documentBlobUrl}')");
            documentBlobUrl = null;
        }
    }

    private void OnControlChanged((string id, object value) args)
    {
        if (sample is InteractiveSampleBase interactive)
        {
            interactive.UpdateControl(args.id, args.value);
            GenerateDocumentIfNeeded();
        }
    }

    private void GenerateDocumentIfNeeded()
    {
        if (sample is DocumentSampleBase doc)
        {
            // Clear old blob
            if (!string.IsNullOrEmpty(documentBlobUrl))
            {
                _ = JS.InvokeVoidAsync("eval", $"URL.revokeObjectURL('{documentBlobUrl}')");
                documentBlobUrl = null;
            }

            // Generate the document (calls OnGenerateDocument which populates DocumentBytes)
            using var tempSurface = SKSurface.Create(new SKImageInfo(1, 1));
            doc.DrawSample(tempSurface.Canvas, 1, 1);

            // Create blob URL for the viewer
            UpdateDocumentPreview();
        }
    }

    public void Dispose() => DisposeSample();
}
