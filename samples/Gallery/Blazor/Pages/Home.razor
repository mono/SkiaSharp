@page "/"

<PageTitle>SkiaSharp Gallery</PageTitle>

<h1>SkiaSharp Gallery</h1>

<p>
    Welcome to the <strong>SkiaSharp Gallery</strong> — a collection of interactive samples demonstrating
    the capabilities of <a href="https://github.com/mono/SkiaSharp" target="_blank">SkiaSharp</a>,
    a cross-platform 2D graphics API for .NET.
</p>

<p>
    Browse the samples in the sidebar. Each sample demonstrates a specific SkiaSharp feature,
    rendered in the browser using WebAssembly.
</p>

<div class="row mt-4">
    <div class="col-md-6 mb-3">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">🎨 Drawing Primitives</h5>
                <p class="card-text">Shapes, paths, text, and transformations using the SkiaSharp canvas API.</p>
            </div>
        </div>
    </div>
    <div class="col-md-6 mb-3">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">✨ Shaders & Effects</h5>
                <p class="card-text">Gradients, image filters, color filters, mask filters, and path effects.</p>
            </div>
        </div>
    </div>
    <div class="col-md-6 mb-3">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">🖼️ Bitmaps & Images</h5>
                <p class="card-text">Bitmap decoding, pixel manipulation, and various image format support.</p>
            </div>
        </div>
    </div>
    <div class="col-md-6 mb-3">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">🔤 Text & Fonts</h5>
                <p class="card-text">Text rendering, font loading, HarfBuzz text shaping, and Unicode support.</p>
            </div>
        </div>
    </div>
    <div class="col-md-6 mb-3">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">🎬 Animation</h5>
                <p class="card-text">Animated samples including Lottie/Skottie animations and procedural effects.</p>
            </div>
        </div>
    </div>
    <div class="col-md-6 mb-3">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">📄 Documents</h5>
                <p class="card-text">PDF document generation using SkiaSharp's document API.</p>
            </div>
        </div>
    </div>
</div>

<hr />

<p class="text-muted small">
    SkiaSharp: <strong>@SamplesManager.SkiaSharpVersion</strong> &nbsp;|&nbsp;
    HarfBuzzSharp: <strong>@SamplesManager.HarfBuzzSharpVersion</strong>
</p>
