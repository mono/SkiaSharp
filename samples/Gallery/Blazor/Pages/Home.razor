@page "/"
@inject SkiaSharpSample.Services.ISampleService SampleService

<PageTitle>SkiaSharp Gallery</PageTitle>

<h1>SkiaSharp Gallery</h1>

<p>
    Welcome to the <strong>SkiaSharp Gallery</strong> — a collection of interactive samples demonstrating
    the capabilities of <a href="https://github.com/mono/SkiaSharp" target="_blank">SkiaSharp</a>,
    a cross-platform 2D graphics API for .NET.
</p>

<p>
    Browse the samples in the sidebar. Each sample demonstrates a specific SkiaSharp feature,
    rendered in the browser using WebAssembly.
</p>

<div class="row mt-4">
    <div class="col-md-6 mb-3">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">🌟 Showcases</h5>
                <p class="card-text">Interactive demos featuring Lottie animation, vector art, 3D rotation, and freehand drawing.</p>
            </div>
        </div>
    </div>
    <div class="col-md-6 mb-3">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">✨ Shaders &amp; Effects</h5>
                <p class="card-text">Gradients, blend modes, sweep gradients, noise generation, and shader composition.</p>
            </div>
        </div>
    </div>
    <div class="col-md-6 mb-3">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">🖼️ Image &amp; Filters</h5>
                <p class="card-text">Blur image filters and photo manipulation with interactive controls.</p>
            </div>
        </div>
    </div>
    <div class="col-md-6 mb-3">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">🔤 Text &amp; Typography</h5>
                <p class="card-text">Text rendering, text on paths, world text, and interactive text lab.</p>
            </div>
        </div>
    </div>
    <div class="col-md-6 mb-3">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">📐 Paths &amp; Geometry</h5>
                <p class="card-text">Path construction, path effects, and geometric transformations.</p>
            </div>
        </div>
    </div>
    <div class="col-md-6 mb-3">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">🖼️ Image Decoding</h5>
                <p class="card-text">Decode images in various formats including PNG, WebP, DNG, and animated GIFs.</p>
            </div>
        </div>
    </div>
    <div class="col-md-6 mb-3">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">⚙️ General</h5>
                <p class="card-text">Canvas transforms, nine-patch scaling, vertex meshes, and more.</p>
            </div>
        </div>
    </div>
    <div class="col-md-6 mb-3">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">📄 Documents</h5>
                <p class="card-text">PDF and XPS document generation with configurable page sizes.</p>
            </div>
        </div>
    </div>
</div>

<hr />

<p class="text-muted small">
    SkiaSharp: <strong>@SampleService.SkiaSharpVersion</strong> &nbsp;|&nbsp;
    HarfBuzzSharp: <strong>@SampleService.HarfBuzzSharpVersion</strong>
</p>
