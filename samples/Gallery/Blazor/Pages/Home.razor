@page "/"
@using SkiaSharpSample.Services
@inject ISampleService SampleService

<PageTitle>SkiaSharp Gallery</PageTitle>

<div class="home-container">
    <div class="hero-section" style="position:relative;overflow:hidden;">
        <SKCanvasView OnPaintSurface="OnHeroPaint"
                      EnableRenderLoop="true"
                      IgnorePixelScaling="true"
                      style="position:absolute;inset:0;width:100%;height:100%;display:block;opacity:0.15;" />
        <div style="position:relative;z-index:1;">
            <h1 class="hero-title">SkiaSharp Gallery</h1>
            <p class="hero-subtitle">Interactive demos showcasing SkiaSharp's 2D graphics capabilities. Built with Blazor WebAssembly.</p>
        </div>
    </div>

    <div class="d-flex gap-2 mb-3 align-items-center flex-wrap">
        <div class="flex-grow-1">
            <input class="form-control search-input" type="search" placeholder="Search samples..."
                   @bind="searchText" @bind:event="oninput" />
        </div>
        <div class="d-flex flex-wrap gap-1 align-items-center">
            @foreach (var cat in allCategories)
            {
                var color = GetCategoryColor(cat);
                var active = selectedCategories.Contains(cat);
                <button class="btn btn-sm filter-chip @(active ? "active" : "")"
                        style="--chip-color: @color;"
                        @onclick="() => ToggleCategory(cat)">
                    <span class="chip-dot" style="background-color: @color;"></span>
                    @cat
                </button>
            }
            <button class="btn btn-sm btn-link text-muted p-0 ms-1" @onclick="ToggleAll" style="font-size:0.75rem;">
                @(selectedCategories.Count == allCategories.Length ? "Clear" : "All")
            </button>
        </div>
    </div>

    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-3 g-3 mb-4">
        @{ var index = 0; }
        @foreach (var sample in GetFilteredSamples())
        {
            var i = index++;
            var categoryColor = GetCategoryColor(sample.Category);
            var icon = GetSampleIcon(sample.Title);
            <div class="col">
                <a href="sample/@Uri.EscapeDataString(sample.Title)" class="text-decoration-none">
                    <div class="card h-100 sample-card" style="border-left-color: @categoryColor; background-color: @(categoryColor)08; animation-delay: @(i * 40)ms;">
                        @if (thumbnails.TryGetValue(sample.Title, out var thumb))
                        {
                            <img src="@thumb" alt="@sample.Title preview" class="card-thumbnail" />
                        }
                        else
                        {
                            <div class="card-preview" style="background: linear-gradient(135deg, @(categoryColor)20, @(categoryColor)40);"></div>
                        }
                        <div class="card-body py-3 px-3">
                            <div class="d-flex align-items-start gap-2">
                                <i class="bi @icon" style="font-size:1.4rem;color:@categoryColor;flex-shrink:0;margin-top:1px;"></i>
                                <div>
                                    <h6 class="card-title mb-1">@sample.Title</h6>
                                    @if (!string.IsNullOrWhiteSpace(sample.Description))
                                    {
                                        <p class="card-text text-muted small mb-0" style="line-height: 1.4;">
                                            @TruncateDescription(sample.Description)
                                        </p>
                                    }
                                </div>
                            </div>
                        </div>
                        <div class="card-footer bg-transparent border-0 py-2 px-3">
                            <span class="category-badge" style="background-color: @(categoryColor)1A; color: @categoryColor;">@sample.Category</span>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>

    <hr class="mt-4" />
    <p class="text-muted small">
        SkiaSharp: <strong>@SampleService.SkiaSharpVersion</strong> &nbsp;|&nbsp;
        HarfBuzzSharp: <strong>@SampleService.HarfBuzzSharpVersion</strong>
    </p>
</div>

@code {
    private string searchText = string.Empty;
    private HashSet<string> selectedCategories = new();
    private string[] allCategories = Array.Empty<string>();
    private Dictionary<string, string> thumbnails = new();
    private float heroTime;
    private DateTime lastHeroFrame = DateTime.UtcNow;

    protected override void OnInitialized()
    {
        allCategories = SampleService.GetSamples()
            .Select(s => s.Category)
            .Distinct()
            .OrderBy(c => c)
            .ToArray();
        selectedCategories = new HashSet<string>(allCategories);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            foreach (var sample in SampleService.GetSamples())
            {
                try
                {
                    var tempSample = (SampleBase)Activator.CreateInstance(sample.GetType())!;
                    tempSample.Init();

                    // Poll for init completion (Init is async void)
                    for (int i = 0; i < 50 && !tempSample.IsInitialized; i++)
                        await Task.Delay(50);

                    if (!tempSample.IsInitialized) continue;

                    using var surface = SKSurface.Create(new SKImageInfo(320, 180));
                    if (surface == null) continue;

                    tempSample.DrawSample(surface.Canvas, 320, 180);
                    using var image = surface.Snapshot();
                    using var data = image.Encode(SKEncodedImageFormat.Png, 60);
                    var base64 = Convert.ToBase64String(data.ToArray());
                    thumbnails[sample.Title] = $"data:image/png;base64,{base64}";
                    tempSample.Destroy();
                }
                catch { }
            }
            await InvokeAsync(StateHasChanged);
        }
    }

    private void OnHeroPaint(SKPaintSurfaceEventArgs e)
    {
        var now = DateTime.UtcNow;
        heroTime += (float)(now - lastHeroFrame).TotalSeconds;
        lastHeroFrame = now;

        var canvas = e.Surface.Canvas;
        var width = e.Info.Width;
        var height = e.Info.Height;
        canvas.Clear(SKColors.Transparent);

        // Draw 4 soft gradient circles that drift slowly
        var blobs = new[] {
            (cx: 0.3f, cy: 0.4f, r: 0.35f, speed: 0.3f, color: new SKColor(0x1A, 0x23, 0x7E)),
            (cx: 0.7f, cy: 0.3f, r: 0.3f, speed: 0.4f, color: new SKColor(0x15, 0x65, 0xC0)),
            (cx: 0.5f, cy: 0.7f, r: 0.25f, speed: 0.5f, color: new SKColor(0x6A, 0x1B, 0x9A)),
            (cx: 0.2f, cy: 0.6f, r: 0.2f, speed: 0.35f, color: new SKColor(0x00, 0x89, 0x7B)),
        };

        foreach (var blob in blobs)
        {
            var x = (blob.cx + MathF.Sin(heroTime * blob.speed) * 0.1f) * width;
            var y = (blob.cy + MathF.Cos(heroTime * blob.speed * 0.7f) * 0.08f) * height;
            var r = blob.r * Math.Min(width, height);

            using var shader = SKShader.CreateRadialGradient(
                new SKPoint(x, y), r,
                new[] { blob.color.WithAlpha(80), blob.color.WithAlpha(0) },
                null, SKShaderTileMode.Clamp);
            using var paint = new SKPaint { Shader = shader, IsAntialias = true };
            canvas.DrawCircle(x, y, r, paint);
        }
    }

    private IEnumerable<SampleBase> GetFilteredSamples()
    {
        return SampleService.GetSamples()
            .Where(s => s.MatchesFilter(searchText))
            .Where(s => selectedCategories.Contains(s.Category))
            .OrderBy(s => s.Title);
    }

    private void ToggleCategory(string category)
    {
        if (!selectedCategories.Remove(category))
            selectedCategories.Add(category);
    }

    private void ToggleAll()
    {
        if (selectedCategories.Count == allCategories.Length)
            selectedCategories.Clear();
        else
            selectedCategories = new HashSet<string>(allCategories);
    }

    private static string TruncateDescription(string desc)
    {
        return desc.Length > 120 ? desc[..117] + "..." : desc;
    }

    private static string GetCategoryColor(string category) => category switch
    {
        SampleCategories.Documents => "#607D8B",
        SampleCategories.General => "#1A237E",
        SampleCategories.ImageFilters => "#E65100",
        SampleCategories.BitmapDecoding => "#00897B",
        SampleCategories.PathEffects => "#6A1B9A",
        SampleCategories.Paths => "#2E7D32",
        SampleCategories.Shaders => "#1565C0",
        SampleCategories.Text => "#AD1457",
        _ => "#546E7A",
    };

    private static string GetSampleIcon(string title) => title switch
    {
        "Blend Modes" => "bi-layers-half",
        "Blur Image Filter" => "bi-droplet-half",
        "2D Transforms" => "bi-arrows-move",
        "3D Transforms" => "bi-box",
        "Create XPS Document" => "bi-file-earmark-richtext",
        "GIF Player" => "bi-film",
        "Gradient" => "bi-rainbow",
        "Image Decoder" => "bi-file-image",
        "Lottie Player" => "bi-play-circle",
        "Nine-Patch Scaler" => "bi-grid-3x3",
        "Noise Generator" => "bi-soundwave",
        "Path Builder" => "bi-pentagon",
        "Path Effects Lab" => "bi-bezier2",
        "PDF Composer" => "bi-file-pdf",
        "Photo Lab" => "bi-camera",
        "Shader Playground" => "bi-lightning",
        "Text Lab" => "bi-fonts",
        "Text on Path" => "bi-type",
        "Vector Art" => "bi-vector-pen",
        "Vertex Mesh" => "bi-diagram-3",
        "World Text" => "bi-globe2",
        _ => "bi-brush",
    };
}
