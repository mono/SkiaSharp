@using SkiaSharpSample.Controls

@if (Controls is { Count: > 0 })
{
    <div class="control-panel p-3 border rounded bg-light mt-2">
        @foreach (var control in Controls)
        {
            <div class="mb-2">
                @if (control is SliderControl slider)
                {
                    <label class="form-label mb-0 small">@slider.Label: <strong>@GetSliderValue(slider.Id, slider.Value).ToString("F1")</strong></label>
                    <input type="range" class="form-range"
                           min="@slider.Min" max="@slider.Max"
                           step="@(slider.Step > 0 ? slider.Step : (slider.Max - slider.Min) / 100f)"
                           value="@GetSliderValue(slider.Id, slider.Value)"
                           @oninput="e => OnSliderChanged(slider.Id, e)" />
                }
                else if (control is ToggleControl toggle)
                {
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox"
                               checked="@GetToggleValue(toggle.Id, toggle.Value)"
                               @onchange="e => OnToggleChanged(toggle.Id, e)" />
                        <label class="form-check-label small">@toggle.Label</label>
                    </div>
                }
                else if (control is PickerControl picker)
                {
                    <label class="form-label mb-0 small">@picker.Label</label>
                    <select class="form-select form-select-sm"
                            value="@GetPickerValue(picker.Id, picker.SelectedIndex)"
                            @onchange="e => OnPickerChanged(picker.Id, e)">
                        @for (var i = 0; i < picker.Options.Length; i++)
                        {
                            <option value="@i">@picker.Options[i]</option>
                        }
                    </select>
                }
            </div>
        }
    </div>
}

@code {
    [Parameter] public IReadOnlyList<SampleControl>? Controls { get; set; }
    [Parameter] public EventCallback<(string id, object value)> OnChanged { get; set; }

    private readonly Dictionary<string, object> values = new();

    private float GetSliderValue(string id, float defaultValue) =>
        values.TryGetValue(id, out var v) ? (float)v : defaultValue;

    private bool GetToggleValue(string id, bool defaultValue) =>
        values.TryGetValue(id, out var v) ? (bool)v : defaultValue;

    private int GetPickerValue(string id, int defaultValue) =>
        values.TryGetValue(id, out var v) ? (int)v : defaultValue;

    private async Task OnSliderChanged(string id, ChangeEventArgs e)
    {
        if (float.TryParse(e.Value?.ToString(), out var val))
        {
            values[id] = val;
            await OnChanged.InvokeAsync((id, (object)val));
        }
    }

    private async Task OnToggleChanged(string id, ChangeEventArgs e)
    {
        var val = (bool)(e.Value ?? false);
        values[id] = val;
        await OnChanged.InvokeAsync((id, (object)val));
    }

    private async Task OnPickerChanged(string id, ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var idx))
        {
            values[id] = idx;
            await OnChanged.InvokeAsync((id, (object)idx));
        }
    }

    public void Reset()
    {
        values.Clear();
    }
}
