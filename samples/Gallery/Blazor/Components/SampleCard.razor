@{
    var isDoc = Sample is DocumentSampleBase;
    var isAnimated = Sample is CanvasSampleBase cs && cs.IsAnimated;
    var sizeClass = CardSize switch
    {
        SampleCardSize.Feature => "card-feature",
        SampleCardSize.Compact => "card-compact",
        _ => "card-standard",
    };
    // Deterministic per-card height variance: hash title to get a stable padding
    var hash = (uint)Sample.Title.GetHashCode();
    var extraPad = 12 + (int)(hash % 40); // 12–51px extra bottom padding
}

<div class="sample-card @sizeClass @(!Supported ? "sample-card-disabled" : "")"
     style="--card-color: @CategoryColor; --card-pad: @(extraPad)px; animation-delay: @(Index * 30)ms;">
    @* Gradient top bar *@
    <div class="card-accent" style="background: linear-gradient(135deg, @CategoryColor, color-mix(in srgb, @CategoryColor 60%, #000));"></div>

    @* Watermark icon *@
    <div class="card-watermark">
        <i class="bi @Icon"></i>
    </div>

    @* NEW glow dot *@
    @if (IsNew)
    {
        <div class="new-dot" title="Recently added"></div>
    }

    @* Content *@
    <div class="card-content">
        <div class="card-icon">
            <i class="bi @Icon" style="color: @(Supported ? CategoryColor : "#777");"></i>
        </div>
        <h3 class="card-title">@Sample.Title</h3>
        @if (CardSize != SampleCardSize.Compact && !string.IsNullOrWhiteSpace(Sample.Description))
        {
            <p class="card-desc">
                @(CardSize == SampleCardSize.Feature ? Sample.Description : TruncateDescription(Sample.Description))
            </p>
        }
    </div>

    @* Metadata strip *@
    <div class="card-meta">
        <span class="meta-category" style="background-color: @(CategoryColor)1A; color: @CategoryColor;">
            @Sample.Category
        </span>
        @if (CardSize != SampleCardSize.Compact)
        {
            @if (isDoc)
            {
                <span class="meta-type meta-doc">📄 Doc</span>
            }
            else if (isAnimated)
            {
                <span class="meta-type meta-animated">🎬 Live</span>
            }
            else
            {
                <span class="meta-type meta-canvas">🖼️ Canvas</span>
            }
        }
        @if (!Supported)
        {
            <span class="meta-type meta-unsupported">🚫</span>
        }
    </div>

    @* Hover reveal *@
    <div class="card-hover-reveal">
        Open <i class="bi bi-arrow-right"></i>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public SampleBase Sample { get; set; } = default!;
    [Parameter, EditorRequired] public string CategoryColor { get; set; } = "";
    [Parameter, EditorRequired] public string Icon { get; set; } = "";
    [Parameter] public int Index { get; set; }
    [Parameter] public bool Supported { get; set; } = true;
    [Parameter] public bool IsNew { get; set; }
    [Parameter] public SampleCardSize CardSize { get; set; } = SampleCardSize.Standard;

    private static string TruncateDescription(string desc) =>
        desc.Length > 100 ? desc[..97] + "…" : desc;
}
