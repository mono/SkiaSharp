@* Design D: Tag Cloud — editorial headline search + varied-size tags with slight rotation *@

<div class="tagcloud">
    <div class="tagcloud-headline">
        <input type="search" placeholder="find something to build…" value="@SearchText"
               @oninput="OnSearch" class="headline-input" />
    </div>
    <div class="tagcloud-tags">
        @foreach (var catName in AllCategories)
        {
            var cat = SampleManager.GetCategoryFor(catName);
            var active = SelectedCategories.Contains(catName);
            var count = SampleManager.GetSampleCount(catName, AllSamples);
            var sizeClass = count >= 6 ? "tag-xl" : count >= 4 ? "tag-lg" : count >= 2 ? "tag-md" : "tag-sm";
            var rotation = (catName.GetHashCode() % 5) - 2; // -2 to +2 degrees
            <button class="tag @sizeClass @(active ? "active" : "")"
                    style="--tag-color: @cat.Color; --tag-rot: @(rotation)deg;"
                    @onclick="() => ToggleCategory(catName)">
                <i class="bi @cat.CssIcon"></i>
                @catName
                <em>@count</em>
            </button>
        }
        <button class="tag-clear" @onclick="ResetAll">
            @(SelectedCategories.Count == AllCategories.Length ? "× clear" : "↻ all")
        </button>
    </div>
</div>

<style>
    .tagcloud {
        padding: 0.5rem 0;
    }

    .tagcloud-headline { margin-bottom: 1rem; }

    .headline-input {
        width: 100%;
        border: none;
        border-bottom: 2px solid #e4e4e7;
        background: transparent;
        font-size: clamp(1.5rem, 4vw, 2.5rem);
        font-weight: 300;
        letter-spacing: -0.02em;
        color: #222;
        outline: none;
        padding: 0.25rem 0;
        transition: border-color 0.3s ease;
    }
    .headline-input:focus { border-bottom-color: #1565C0; }
    .headline-input::placeholder { color: #ccc; }

    .tagcloud-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        align-items: center;
        padding: 0.25rem 0;
    }

    .tag {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        border-radius: 999px;
        border: 1.5px solid color-mix(in srgb, var(--tag-color) 30%, transparent);
        background: color-mix(in srgb, var(--tag-color) 8%, white);
        color: var(--tag-color);
        cursor: pointer;
        transform: rotate(var(--tag-rot));
        transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
        font-weight: 600;
    }
    .tag i { color: var(--tag-color); }
    .tag em { font-style: normal; opacity: 0.5; font-weight: 400; }

    .tag-xl { font-size: 1.1rem; padding: 0.5rem 1.2rem; }
    .tag-lg { font-size: 0.95rem; padding: 0.4rem 1rem; }
    .tag-md { font-size: 0.8rem; padding: 0.35rem 0.85rem; }
    .tag-sm { font-size: 0.7rem; padding: 0.3rem 0.7rem; }

    .tag:hover {
        background: var(--tag-color);
        color: white;
        border-color: var(--tag-color);
        transform: rotate(0deg) scale(1.06);
        box-shadow: 0 4px 16px color-mix(in srgb, var(--tag-color) 30%, transparent);
    }
    .tag:hover i { color: white; }

    .tag.active {
        background: color-mix(in srgb, var(--tag-color) 20%, white);
        border-color: var(--tag-color);
        transform: rotate(0deg);
    }
    .tag:not(.active) { opacity: 0.4; transform: rotate(var(--tag-rot)) scale(0.9); }

    .tag-clear {
        font-size: 0.75rem;
        color: #888;
        background: none;
        border: 1px dashed #ccc;
        border-radius: 999px;
        padding: 0.25rem 0.6rem;
        cursor: pointer;
        transition: all 0.2s ease;
    }
    .tag-clear:hover { border-color: #666; color: #333; }

    [data-theme="dark"] .headline-input { color: #e0e0e0; border-bottom-color: #333; }
    [data-theme="dark"] .headline-input:focus { border-bottom-color: #5DADE2; }
    [data-theme="dark"] .headline-input::placeholder { color: #555; }
    [data-theme="dark"] .tag { background: color-mix(in srgb, var(--tag-color) 15%, #1e1e2e); border-color: color-mix(in srgb, var(--tag-color) 25%, #333); }
    [data-theme="dark"] .tag.active { background: color-mix(in srgb, var(--tag-color) 25%, #1e1e2e); }
    [data-theme="dark"] .tag:hover { background: var(--tag-color); color: white; }
    [data-theme="dark"] .tag-clear { border-color: #444; color: #666; }
</style>

@code {
    [Parameter] public string[] AllCategories { get; set; } = [];
    [Parameter] public HashSet<string> SelectedCategories { get; set; } = new();
    [Parameter] public string SearchText { get; set; } = "";
    [Parameter] public SampleBase[] AllSamples { get; set; } = [];
    [Parameter] public EventCallback<string> OnSearchChanged { get; set; }
    [Parameter] public EventCallback<HashSet<string>> OnCategoriesChanged { get; set; }

    private async Task OnSearch(ChangeEventArgs e) =>
        await OnSearchChanged.InvokeAsync(e.Value?.ToString() ?? "");

    private async Task ToggleCategory(string cat)
    {
        var copy = new HashSet<string>(SelectedCategories);
        if (!copy.Remove(cat)) copy.Add(cat);
        await OnCategoriesChanged.InvokeAsync(copy);
    }

    private async Task ResetAll()
    {
        var copy = SelectedCategories.Count == AllCategories.Length
            ? new HashSet<string>()
            : new HashSet<string>(AllCategories);
        await OnCategoriesChanged.InvokeAsync(copy);
    }
}
