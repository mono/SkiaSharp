@* Design C: Constellation — floating colored bubbles sized by sample count *@

<div class="constellation">
    <div class="orbs">
        @foreach (var catName in AllCategories)
        {
            var cat = SampleManager.GetCategoryFor(catName);
            var active = SelectedCategories.Contains(catName);
            var count = SampleManager.GetSampleCount(catName, AllSamples);
            var size = 48 + count * 5;
            <button class="orb @(active ? "active" : "")"
                    style="--orb-color: @cat.Color; --orb-size: @(size)px;"
                    @onclick="() => ToggleCategory(catName)">
                <i class="bi @cat.CssIcon"></i>
                <span class="orb-label">@ShortName(catName)</span>
                <span class="orb-count">@count</span>
            </button>
        }
    </div>
    <div class="horizon">
        <i class="bi bi-search"></i>
        <input type="search" placeholder="Search samples…" value="@SearchText"
               @oninput="OnSearch" />
    </div>
</div>

<style>
    .constellation { text-align: center; padding: 0.5rem 0 0; }

    .orbs {
        display: flex;
        justify-content: center;
        gap: 0.75rem;
        flex-wrap: wrap;
        padding: 0.5rem 0 1rem;
    }

    .orb {
        width: var(--orb-size);
        height: var(--orb-size);
        border-radius: 50%;
        border: 2px solid color-mix(in srgb, var(--orb-color) 40%, transparent);
        background: radial-gradient(circle at 35% 35%, rgba(255,255,255,0.8), color-mix(in srgb, var(--orb-color) 25%, white) 70%);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 0.1rem;
        cursor: pointer;
        transition: all 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
        filter: drop-shadow(0 4px 12px color-mix(in srgb, var(--orb-color) 30%, transparent));
        animation: orbFloat 6s ease-in-out infinite;
        animation-delay: calc(var(--orb-size) * 10ms);
    }

    @@keyframes orbFloat {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-5px); }
    }

    .orb:hover {
        transform: scale(1.12);
        filter: drop-shadow(0 8px 20px color-mix(in srgb, var(--orb-color) 45%, transparent));
    }
    .orb.active {
        border-color: var(--orb-color);
        background: radial-gradient(circle at 35% 35%, rgba(255,255,255,0.9), color-mix(in srgb, var(--orb-color) 40%, white) 70%);
    }
    .orb:not(.active) { opacity: 0.35; transform: scale(0.85); filter: none; }

    .orb i { font-size: 1rem; color: var(--orb-color); }
    .orb-label { font-size: 0.55rem; font-weight: 700; color: #444; line-height: 1; }
    .orb-count { font-size: 0.5rem; color: #888; }

    .horizon {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        padding: 0.5rem 0;
        border-top: 1.5px solid #e4e4e7;
    }
    .horizon i { color: #999; }
    .horizon input {
        border: none;
        background: transparent;
        outline: none;
        font-size: 0.95rem;
        text-align: center;
        width: 250px;
        color: inherit;
    }
    .horizon input::placeholder { color: #bbb; }

    [data-theme="dark"] .orb { background: radial-gradient(circle at 35% 35%, rgba(255,255,255,0.1), color-mix(in srgb, var(--orb-color) 30%, #1e1e2e) 70%); }
    [data-theme="dark"] .orb-label { color: #ccc; }
    [data-theme="dark"] .horizon { border-top-color: #333; }
    [data-theme="dark"] .horizon input { color: #e0e0e0; }

    @@media (prefers-reduced-motion: reduce) { .orb { animation: none; } }
</style>

@code {
    [Parameter] public string[] AllCategories { get; set; } = [];
    [Parameter] public HashSet<string> SelectedCategories { get; set; } = new();
    [Parameter] public string SearchText { get; set; } = "";
    [Parameter] public SampleBase[] AllSamples { get; set; } = [];
    [Parameter] public EventCallback<string> OnSearchChanged { get; set; }
    [Parameter] public EventCallback<HashSet<string>> OnCategoriesChanged { get; set; }

    private async Task OnSearch(ChangeEventArgs e) =>
        await OnSearchChanged.InvokeAsync(e.Value?.ToString() ?? "");

    private async Task ToggleCategory(string cat)
    {
        var copy = new HashSet<string>(SelectedCategories);
        if (!copy.Remove(cat)) copy.Add(cat);
        await OnCategoriesChanged.InvokeAsync(copy);
    }

    private static string ShortName(string cat) => cat switch
    {
        "Image & Filters" => "Filters",
        "Shaders & Effects" => "Shaders",
        "Text & Typography" => "Text",
        "Paths & Geometry" => "Paths",
        "Image Decoding" => "Decode",
        _ => cat,
    };
}
