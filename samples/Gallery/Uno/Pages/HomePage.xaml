<Page x:Class="SkiaSharpSample.Pages.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:shared="using:SkiaSharpSample"
      xmlns:local="using:SkiaSharpSample.Pages"
      xmlns:controls="using:SkiaSharpSample.Controls"
      mc:Ignorable="d">

    <ScrollViewer>
        <Grid MaxWidth="1200" Padding="24,16" HorizontalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Spacing="8" Margin="0,8,0,16">
                <Border Width="48"
                        Height="4"
                        CornerRadius="2"
                        HorizontalAlignment="Left">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                            <GradientStop Color="#1A237E" Offset="0" />
                            <GradientStop Color="#1565C0" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
                <TextBlock Text="SkiaSharp Gallery"
                           FontSize="32"
                           FontWeight="Bold" />
                <TextBlock Text="Interactive demos showcasing SkiaSharp's 2D graphics capabilities. Built with Uno Platform."
                           FontSize="15"
                           Opacity="0.7"
                           TextWrapping="Wrap" />
            </StackPanel>

            <TextBox x:Name="SearchBox"
                     Grid.Row="1"
                     PlaceholderText="Search samples..."
                     TextChanged="OnSearchChanged"
                     Margin="0,0,0,8" />

            <controls:WrapPanel x:Name="CategoryChipsHost"
                                Grid.Row="2"
                                HorizontalSpacing="6"
                                VerticalSpacing="6"
                                Margin="0,0,0,16" />

            <!-- Children built in code-behind: GridView / ItemsRepeater don't
                 render reliably under Uno 6.6 SkiaRenderer on -browserwasm. -->
            <StackPanel x:Name="CardGridHost"
                        Grid.Row="3"
                        Spacing="12" />

            <Border Grid.Row="4"
                    Margin="0,24,0,0"
                    Padding="0,12,0,0"
                    BorderThickness="0,1,0,0"
                    BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}">
                <TextBlock x:Name="FooterText"
                           FontSize="12"
                           Opacity="0.6"
                           TextWrapping="Wrap" />
            </Border>
        </Grid>
    </ScrollViewer>

</Page>
