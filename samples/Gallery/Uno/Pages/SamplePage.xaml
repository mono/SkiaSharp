<Page x:Class="SkiaSharpSample.Pages.SamplePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:controls="using:SkiaSharpSample.Controls"
      mc:Ignorable="d">

    <Grid Padding="24,16" MaxWidth="1400" HorizontalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="6" Margin="0,0,0,12">
            <HyperlinkButton x:Name="BackLink"
                             Click="OnBackClicked"
                             Padding="0"
                             Margin="0">
                <TextBlock Text="← Back to Gallery" FontSize="12" />
            </HyperlinkButton>
            <TextBlock x:Name="TitleText"
                       FontSize="32"
                       FontWeight="SemiBold"
                       Margin="0,0,0,0" />
            <TextBlock x:Name="DescriptionText"
                       FontSize="13"
                       Opacity="0.7"
                       TextWrapping="Wrap" />
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    x:Name="CanvasBorder"
                    BorderThickness="1"
                    BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                    Background="White"
                    CornerRadius="6"
                    Margin="0,0,12,0" />

            <Border Grid.Column="1"
                    x:Name="ControlsSidebar"
                    Width="290"
                    Background="#F8F9FA"
                    CornerRadius="6"
                    Padding="12"
                    Visibility="Collapsed"
                    RequestedTheme="Light">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="4,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="CONTROLS"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Opacity="0.6"
                                   VerticalAlignment="Center" />
                        <Button Grid.Column="1"
                                x:Name="CollapseButton"
                                Click="OnCollapseClicked"
                                Background="Transparent"
                                BorderThickness="1"
                                BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                                CornerRadius="4"
                                MinHeight="0"
                                MinWidth="0"
                                Padding="6,2"
                                ToolTipService.ToolTip="Toggle controls panel">
                            <TextBlock x:Name="CollapseIcon" Text="◀" FontSize="10" />
                        </Button>
                    </Grid>

                    <Border Grid.Row="1"
                            Background="White"
                            BorderThickness="1"
                            BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                            CornerRadius="6"
                            Padding="12">
                        <ScrollViewer>
                            <StackPanel Spacing="12">
                                <controls:ControlPanelView x:Name="ControlPanel" />
                                <Button x:Name="DownloadButton"
                                        Click="OnDownloadClicked"
                                        HorizontalAlignment="Stretch"
                                        Visibility="Collapsed"
                                        Margin="0,8,0,0">
                                    <TextBlock Text="⬇ Download" />
                                </Button>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <TextBlock x:Name="CanvasInfoText"
                   Grid.Row="2"
                   Margin="0,8,0,0"
                   FontSize="11"
                   Opacity="0.5" />
    </Grid>

</Page>
