<linker>
  <!-- Host assembly (template uses the single-project name which matches the csproj) -->
  <assembly fullname="SkiaSharpSample.Uno" />
  <!--
    The shared sample catalog (SkiaSharpSample.Shared) discovers SampleBase
    subclasses via reflection over Assembly.DefinedTypes. Preserve the entire
    assembly so the linker (aggressive under Uno.Sdk 6.6 Release) doesn't
    trim the sample classes and leave GetAllSamples() empty.
  -->
  <assembly fullname="SkiaSharpSample.Shared" />
</linker>
