@inherits LayoutComponentBase
@inject IJSRuntime JS

<div class="page">
    <main>
        <div class="top-row px-4">
            <a class="navbar-brand" href="">SkiaSharp Gallery</a>
            <div class="ms-auto d-flex align-items-center gap-3">
                <div class="btn-group btn-group-sm" role="group">
                    <button type="button" class="btn @(UseGpu ? "btn-outline-secondary" : "btn-secondary") btn-sm" @onclick="() => SetBackend(false)">CPU</button>
                    <button type="button" class="btn @(UseGpu ? "btn-secondary" : "btn-outline-secondary") btn-sm" @onclick="() => SetBackend(true)">GPU</button>
                </div>
                <button class="btn btn-sm btn-outline-light" @onclick="ToggleDarkMode" title="Toggle dark mode">
                    @(darkMode ? "☀️" : "🌙")
                </button>
                <a href="https://github.com/mono/SkiaSharp" target="_blank">GitHub</a>
            </div>
        </div>
        <article class="content px-4">
            <CascadingValue Value="UseGpu" Name="UseGpu">
                <CascadingValue Value="BackendChanged" Name="BackendChanged">
                    @Body
                </CascadingValue>
            </CascadingValue>
        </article>
    </main>
</div>

@code {
    public bool UseGpu { get; set; } = true;
    public EventCallback BackendChanged => EventCallback.Factory.Create(this, () => { });
    private static bool darkMode = false;

    private void SetBackend(bool gpu)
    {
        UseGpu = gpu;
    }

    private async Task ToggleDarkMode()
    {
        darkMode = !darkMode;
        await JS.InvokeVoidAsync("eval",
            darkMode ? "document.documentElement.setAttribute('data-theme','dark')"
                     : "document.documentElement.removeAttribute('data-theme')");
    }
}
