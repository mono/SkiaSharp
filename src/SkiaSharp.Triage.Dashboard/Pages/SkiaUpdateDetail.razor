@page "/skia-updates/{Number:int}"
@inject DashboardDataService DataService
@inject NavigationManager Navigation

<PageTitle>Skia PR #@Number Review - SkiaSharp Dashboard</PageTitle>

@if (_loading)
{
    <p><em>Loading review data...</em></p>
}
else if (_review is null)
{
    <h1>Review Not Found</h1>
    <p>No review data for Skia PR #@Number.</p>
    <a href="skia-updates" class="btn-back">← Back to Skia Updates</a>
}
else
{
    <div class="skia-detail-nav">
        <a href="skia-updates" class="btn-back">← Back to Skia Updates</a>
    </div>

    <!-- Header -->
    <div class="triage-detail-header triage-detail-header-minimal">
        <div class="detail-title-row">
            <a href="https://github.com/mono/skia/pull/@_review.Meta.SkiaPrNumber" target="_blank" rel="noopener noreferrer" class="issue-link-lg">#@_review.Meta.SkiaPrNumber</a>
            <h1>@(_indexEntry?.PrTitle ?? $"Skia Update: {FormatBranch(_review.Meta.OldUpstreamBranch)} → {FormatBranch(_review.Meta.UpstreamBranch)}")</h1>
        </div>
        <div class="detail-header-meta">
            <span class="badge-risk badge-risk-@_review.RiskAssessment.ToString().ToLower()">
                @_review.RiskAssessment Risk
            </span>
            <span class="detail-meta-text">
                @FormatBranch(_review.Meta.OldUpstreamBranch) → @FormatBranch(_review.Meta.UpstreamBranch)
                · Analyzed: @_review.Meta.AnalyzedAt.ToString("yyyy-MM-dd HH:mm UTC")
                · <a href="https://github.com/mono/skia" target="_blank" rel="noopener noreferrer">mono/skia</a>
            </span>
        </div>
    </div>

    <!-- Quick Facts -->
    <div class="quick-facts-row">
        @if (_indexEntry?.PrState is not null)
        {
            <div class="qf-group">
                <span class="qf-label">State</span>
                <span class="label label-@_indexEntry.PrState">@_indexEntry.PrState</span>
            </div>
        }
        <div class="qf-group">
            <span class="qf-label">Generated</span>
            <span class="section-status @(_review.GeneratedFiles.Status == GeneratedFilesStatus.Pass ? "status-pass" : "status-fail")">
                @(_review.GeneratedFiles.Status == GeneratedFilesStatus.Pass ? "✓ PASS" : "✗ FAIL")
            </span>
        </div>
        <div class="qf-group">
            <span class="qf-label">Upstream</span>
            <span class="section-status @(_review.UpstreamIntegrity.Status == SkiaReviewStatus.Pass ? "status-pass" : "status-review")">
                @(_review.UpstreamIntegrity.Status == SkiaReviewStatus.Pass ? "✓ PASS" : "⚠ REVIEW")
            </span>
        </div>
        <div class="qf-group">
            <span class="qf-label">Interop</span>
            <span class="section-status @(_review.InteropIntegrity.Status == SkiaReviewStatus.Pass ? "status-pass" : "status-review")">
                @(_review.InteropIntegrity.Status == SkiaReviewStatus.Pass ? "✓ PASS" : "⚠ REVIEW")
            </span>
        </div>
        <div class="qf-group">
            <span class="qf-label">DEPS</span>
            <span class="section-status @(_review.DepsAudit.Status == SkiaReviewStatus.Pass ? "status-pass" : "status-review")">
                @(_review.DepsAudit.Status == SkiaReviewStatus.Pass ? "✓ PASS" : "⚠ REVIEW")
            </span>
        </div>
        @if (_review.CompanionPr is not null)
        {
            <div class="qf-group">
                <span class="qf-label">Companion</span>
                <a href="https://github.com/mono/SkiaSharp/pull/@_review.CompanionPr.PrNumber" target="_blank" rel="noopener noreferrer" class="label">
                    SkiaSharp #@_review.CompanionPr.PrNumber
                </a>
            </div>
        }
    </div>

    <!-- Tabs -->
    <div class="content-tabs">
        <button type="button" class="content-tab @(_activeTab == "overview" ? "active" : "")" @onclick='() => _activeTab = "overview"'>
            Overview
        </button>
        <button type="button" class="content-tab @(_activeTab == "generated" ? "active" : "")" @onclick='() => _activeTab = "generated"'>
            Generated Files
        </button>
        <button type="button" class="content-tab @(_activeTab == "upstream" ? "active" : "")" @onclick='() => _activeTab = "upstream"'>
            Upstream (@(_review.UpstreamIntegrity.Added.Count + _review.UpstreamIntegrity.Removed.Count + _review.UpstreamIntegrity.Changed.Count))
        </button>
        <button type="button" class="content-tab @(_activeTab == "interop" ? "active" : "")" @onclick='() => _activeTab = "interop"'>
            Interop (@_review.InteropIntegrity.Changed.Count)
        </button>
        <button type="button" class="content-tab @(_activeTab == "deps" ? "active" : "")" @onclick='() => _activeTab = "deps"'>
            DEPS (@(_review.DepsAudit.Added.Count + _review.DepsAudit.Changed.Count))
        </button>
        @if (_review.CompanionPr is not null)
        {
            <button type="button" class="content-tab @(_activeTab == "companion" ? "active" : "")" @onclick='() => _activeTab = "companion"'>
                Companion PR
            </button>
        }
    </div>

    <!-- Tab: Overview -->
    @if (_activeTab == "overview")
    {
        <div class="section-card">
            <h3 class="section-title">Change Summary</h3>

            @if (!string.IsNullOrEmpty(_review.Summary))
            {
                <div class="executive-summary">@_review.Summary</div>
            }

            @if (_review.Recommendations is { Count: > 0 })
            {
                <div class="section-recommendations">
                    <h4>Key Recommendations</h4>
                    <ul>
                        @foreach (var rec in _review.Recommendations)
                        {
                            <li>@rec</li>
                        }
                    </ul>
                </div>
            }

            <p>
                This review covers the Skia upstream merge from
                <strong>@_review.Meta.OldUpstreamBranch</strong> to <strong>@_review.Meta.UpstreamBranch</strong>.
            </p>

            <div class="overview-grid">
                <div class="overview-item @(_review.GeneratedFiles.Status == GeneratedFilesStatus.Pass ? "ov-pass" : "ov-fail")">
                    <div class="ov-header">
                        <span class="section-status @(_review.GeneratedFiles.Status == GeneratedFilesStatus.Pass ? "status-pass" : "status-fail")">
                            @(_review.GeneratedFiles.Status == GeneratedFilesStatus.Pass ? "✓ PASS" : "✗ FAIL")
                        </span>
                        Generated Files
                    </div>
                    <div class="ov-detail">@_review.GeneratedFiles.Checked.Count files verified</div>
                    @if (_review.GeneratedFiles.Mismatches is { Count: > 0 })
                    {
                        <div class="ov-detail count-removed">@_review.GeneratedFiles.Mismatches.Count mismatches</div>
                    }
                </div>

                @{ var us = _review.UpstreamIntegrity; }
                <div class="overview-item @(us.Status == SkiaReviewStatus.Pass ? "ov-pass" : "ov-review")">
                    <div class="ov-header">
                        <span class="section-status @(us.Status == SkiaReviewStatus.Pass ? "status-pass" : "status-review")">
                            @(us.Status == SkiaReviewStatus.Pass ? "✓ PASS" : "⚠ REVIEW")
                        </span>
                        Upstream Integrity
                    </div>
                    <div class="ov-detail">
                        @if (us.Added.Count > 0) { <span class="count-added">+@us.Added.Count</span> }
                        @if (us.Removed.Count > 0) { <span class="count-removed">-@us.Removed.Count</span> }
                        @if (us.Changed.Count > 0) { <span class="count-changed">~@us.Changed.Count</span> }
                        <span class="count-unchanged">@us.Unchanged unchanged</span>
                    </div>
                </div>

                @{ var ip = _review.InteropIntegrity; }
                <div class="overview-item @(ip.Status == SkiaReviewStatus.Pass ? "ov-pass" : "ov-review")">
                    <div class="ov-header">
                        <span class="section-status @(ip.Status == SkiaReviewStatus.Pass ? "status-pass" : "status-review")">
                            @(ip.Status == SkiaReviewStatus.Pass ? "✓ PASS" : "⚠ REVIEW")
                        </span>
                        Interop Integrity
                    </div>
                    <div class="ov-detail">
                        @if (ip.Added.Count > 0) { <span class="count-added">+@ip.Added.Count</span> }
                        @if (ip.Removed.Count > 0) { <span class="count-removed">-@ip.Removed.Count</span> }
                        @if (ip.Changed.Count > 0) { <span class="count-changed">~@ip.Changed.Count</span> }
                        <span class="count-unchanged">@ip.Unchanged unchanged</span>
                    </div>
                </div>

                <div class="overview-item @(_review.DepsAudit.Status == SkiaReviewStatus.Pass ? "ov-pass" : "ov-review")">
                    <div class="ov-header">
                        <span class="section-status @(_review.DepsAudit.Status == SkiaReviewStatus.Pass ? "status-pass" : "status-review")">
                            @(_review.DepsAudit.Status == SkiaReviewStatus.Pass ? "✓ PASS" : "⚠ REVIEW")
                        </span>
                        DEPS Audit
                    </div>
                    <div class="ov-detail">
                        @if (_review.DepsAudit.Added.Count > 0) { <span class="count-added">+@_review.DepsAudit.Added.Count</span> }
                        @if (_review.DepsAudit.Removed.Count > 0) { <span class="count-removed">-@_review.DepsAudit.Removed.Count</span> }
                        @if (_review.DepsAudit.Changed.Count > 0) { <span class="count-changed">~@_review.DepsAudit.Changed.Count</span> }
                        <span class="count-unchanged">@_review.DepsAudit.Unchanged unchanged</span>
                    </div>
                </div>
            </div>

            <h3 class="section-title">Commit SHAs</h3>
            <div class="skia-shas">
                <span><strong>PR Head:</strong> <code>@Truncate(_review.Meta.Shas.PrHead)</code></span>
                <span><strong>Base:</strong> <code>@Truncate(_review.Meta.Shas.Base)</code></span>
                <span><strong>Upstream:</strong> <code>@Truncate(_review.Meta.Shas.Upstream)</code></span>
            </div>
        </div>
    }

    <!-- Tab: Generated Files -->
    @if (_activeTab == "generated")
    {
        <div class="section-card">
            <div class="tab-section-header">
                <span class="section-status @(_review.GeneratedFiles.Status == GeneratedFilesStatus.Pass ? "status-pass" : "status-fail")">
                    @(_review.GeneratedFiles.Status == GeneratedFilesStatus.Pass ? "✓ PASS" : "✗ FAIL")
                </span>
                <h3 class="section-title">Generated Files Check</h3>
            </div>
            @if (!string.IsNullOrEmpty(_review.GeneratedFiles.Summary))
            {
                <p class="section-summary">@_review.GeneratedFiles.Summary</p>
            }
            @if (_review.GeneratedFiles.Recommendations is { Count: > 0 })
            {
                <div class="section-recommendations">
                    <h4>Recommendations</h4>
                    <ul>
                        @foreach (var rec in _review.GeneratedFiles.Recommendations)
                        {
                            <li>@rec</li>
                        }
                    </ul>
                </div>
            }
            <p>Verified @_review.GeneratedFiles.Checked.Count P/Invoke binding files match independent regeneration:</p>
            <ul class="skia-file-list">
                @foreach (var file in _review.GeneratedFiles.Checked)
                {
                    <li><code>@file</code></li>
                }
            </ul>
            @if (_review.GeneratedFiles.Mismatches is { Count: > 0 })
            {
                <h4>⚠️ Mismatches</h4>
                @foreach (var mismatch in _review.GeneratedFiles.Mismatches)
                {
                    <div class="skia-mismatch">
                        <code>@mismatch.File</code>
                        <pre class="file-content">@mismatch.DiffSummary</pre>
                    </div>
                }
            }
        </div>
    }

    <!-- Tab: Upstream Integrity -->
    @if (_activeTab == "upstream")
    {
        var usTab = _review.UpstreamIntegrity;
        <div class="section-card">
            <div class="tab-section-header">
                <span class="section-status @(usTab.Status == SkiaReviewStatus.Pass ? "status-pass" : "status-review")">
                    @(usTab.Status == SkiaReviewStatus.Pass ? "✓ PASS" : "⚠ REVIEW")
                </span>
                <h3 class="section-title">Upstream Integrity</h3>
                <span class="skia-section-counts">
                    @if (usTab.Added.Count > 0) { <span class="count-added">+@usTab.Added.Count added</span> }
                    @if (usTab.Removed.Count > 0) { <span class="count-removed">-@usTab.Removed.Count removed</span> }
                    @if (usTab.Changed.Count > 0) { <span class="count-changed">~@usTab.Changed.Count changed</span> }
                    @if (usTab.Unchanged > 0) { <span class="count-unchanged">@usTab.Unchanged unchanged</span> }
                </span>
            </div>
            @if (!string.IsNullOrEmpty(usTab.Summary))
            {
                <p class="section-summary">@usTab.Summary</p>
            }
            @if (usTab.Recommendations is { Count: > 0 })
            {
                <div class="section-recommendations">
                    <h4>Recommendations</h4>
                    <ul>
                        @foreach (var rec in usTab.Recommendations)
                        {
                            <li>@rec</li>
                        }
                    </ul>
                </div>
            }
            <p>Files <em>outside</em> interop directories that differ from upstream. These are high-risk — upstream code should rarely be modified.</p>
            @if (usTab.Added.Count > 0)
            {
                <h4 class="change-category cat-added">Added (@usTab.Added.Count)</h4>
                @foreach (var file in usTab.Added)
                {
                    <div class="skia-file-entry file-added">
                        <div class="file-path"><code>@file.Path</code></div>
                        <div class="file-summary">@file.Summary</div>
                        @if (file.Diff is not null)
                        {
                            <button class="btn-diff" @onclick='() => ToggleDiff("us-a-" + file.Path)'>
                                @(_expandedDiffs.Contains("us-a-" + file.Path) ? "Hide diff" : "Show diff")
                            </button>
                            @if (_expandedDiffs.Contains("us-a-" + file.Path))
                            {
                                <pre class="file-content">@file.Diff</pre>
                            }
                        }
                    </div>
                }
            }
            @if (usTab.Removed.Count > 0)
            {
                <h4 class="change-category cat-removed">Removed (@usTab.Removed.Count)</h4>
                @foreach (var file in usTab.Removed)
                {
                    <div class="skia-file-entry file-removed">
                        <div class="file-path"><code>@file.Path</code></div>
                        <div class="file-summary">@file.Summary</div>
                        @if (file.Diff is not null)
                        {
                            <button class="btn-diff" @onclick='() => ToggleDiff("us-r-" + file.Path)'>
                                @(_expandedDiffs.Contains("us-r-" + file.Path) ? "Hide diff" : "Show diff")
                            </button>
                            @if (_expandedDiffs.Contains("us-r-" + file.Path))
                            {
                                <pre class="file-content">@file.Diff</pre>
                            }
                        }
                    </div>
                }
            }
            @if (usTab.Changed.Count > 0)
            {
                <h4 class="change-category cat-changed">Changed (@usTab.Changed.Count)</h4>
                @foreach (var file in usTab.Changed)
                {
                    <div class="skia-file-entry file-changed">
                        <div class="file-path"><code>@file.Path</code></div>
                        <div class="file-summary">@file.Summary</div>
                        @if (file.PatchDiff is not null)
                        {
                            <button class="btn-diff" @onclick='() => ToggleDiff("us-c-" + file.Path)'>
                                @(_expandedDiffs.Contains("us-c-" + file.Path) ? "Hide diff" : "Show diff")
                            </button>
                            @if (_expandedDiffs.Contains("us-c-" + file.Path))
                            {
                                <pre class="file-content">@file.PatchDiff</pre>
                            }
                        }
                        @if (file.OldDiff is not null || file.NewDiff is not null)
                        {
                            <button class="btn-diff" @onclick='() => ToggleDiff("us-c-raw-" + file.Path)'>
                                @(_expandedDiffs.Contains("us-c-raw-" + file.Path) ? "Hide old/new patches" : "Show old/new patches")
                            </button>
                            @if (_expandedDiffs.Contains("us-c-raw-" + file.Path))
                            {
                                @if (file.OldDiff is not null)
                                {
                                    <div class="diff-label">Old patch:</div>
                                    <pre class="file-content">@file.OldDiff</pre>
                                }
                                @if (file.NewDiff is not null)
                                {
                                    <div class="diff-label">New patch:</div>
                                    <pre class="file-content">@file.NewDiff</pre>
                                }
                            }
                        }
                    </div>
                }
            }
        </div>
    }

    <!-- Tab: Interop Integrity -->
    @if (_activeTab == "interop")
    {
        var ipTab = _review.InteropIntegrity;
        <div class="section-card">
            <div class="tab-section-header">
                <span class="section-status @(ipTab.Status == SkiaReviewStatus.Pass ? "status-pass" : "status-review")">
                    @(ipTab.Status == SkiaReviewStatus.Pass ? "✓ PASS" : "⚠ REVIEW")
                </span>
                <h3 class="section-title">Interop Integrity</h3>
                <span class="skia-section-counts">
                    @if (ipTab.Added.Count > 0) { <span class="count-added">+@ipTab.Added.Count added</span> }
                    @if (ipTab.Removed.Count > 0) { <span class="count-removed">-@ipTab.Removed.Count removed</span> }
                    @if (ipTab.Changed.Count > 0) { <span class="count-changed">~@ipTab.Changed.Count changed</span> }
                    @if (ipTab.Unchanged > 0) { <span class="count-unchanged">@ipTab.Unchanged unchanged</span> }
                </span>
            </div>
            @if (!string.IsNullOrEmpty(ipTab.Summary))
            {
                <p class="section-summary">@ipTab.Summary</p>
            }
            @if (ipTab.Recommendations is { Count: > 0 })
            {
                <div class="section-recommendations">
                    <h4>Recommendations</h4>
                    <ul>
                        @foreach (var rec in ipTab.Recommendations)
                        {
                            <li>@rec</li>
                        }
                    </ul>
                </div>
            }
            <p>Files in <code>include/c/</code>, <code>include/xamarin/</code>, <code>src/c/</code>, <code>src/xamarin/</code> — the SkiaSharp C API layer. Changes here are expected during Skia bumps.</p>
            @if (ipTab.Added.Count > 0)
            {
                <h4 class="change-category cat-added">Added (@ipTab.Added.Count)</h4>
                @foreach (var file in ipTab.Added)
                {
                    <div class="skia-file-entry file-added">
                        <div class="file-path"><code>@file.Path</code></div>
                        <div class="file-summary">@file.Summary</div>
                    </div>
                }
            }
            @if (ipTab.Removed.Count > 0)
            {
                <h4 class="change-category cat-removed">Removed (@ipTab.Removed.Count)</h4>
                @foreach (var file in ipTab.Removed)
                {
                    <div class="skia-file-entry file-removed">
                        <div class="file-path"><code>@file.Path</code></div>
                        <div class="file-summary">@file.Summary</div>
                    </div>
                }
            }
            @if (ipTab.Changed.Count > 0)
            {
                <h4 class="change-category cat-changed">Changed (@ipTab.Changed.Count)</h4>
                @foreach (var file in ipTab.Changed)
                {
                    <div class="skia-file-entry file-changed">
                        <div class="file-path"><code>@file.Path</code></div>
                        <div class="file-summary">@file.Summary</div>
                        @if (file.PatchDiff is not null)
                        {
                            <button class="btn-diff" @onclick='() => ToggleDiff("ip-c-" + file.Path)'>
                                @(_expandedDiffs.Contains("ip-c-" + file.Path) ? "Hide diff" : "Show diff")
                            </button>
                            @if (_expandedDiffs.Contains("ip-c-" + file.Path))
                            {
                                <pre class="file-content">@file.PatchDiff</pre>
                            }
                        }
                        @if (file.OldDiff is not null || file.NewDiff is not null)
                        {
                            <button class="btn-diff" @onclick='() => ToggleDiff("ip-c-raw-" + file.Path)'>
                                @(_expandedDiffs.Contains("ip-c-raw-" + file.Path) ? "Hide old/new patches" : "Show old/new patches")
                            </button>
                            @if (_expandedDiffs.Contains("ip-c-raw-" + file.Path))
                            {
                                @if (file.OldDiff is not null)
                                {
                                    <div class="diff-label">Old patch:</div>
                                    <pre class="file-content">@file.OldDiff</pre>
                                }
                                @if (file.NewDiff is not null)
                                {
                                    <div class="diff-label">New patch:</div>
                                    <pre class="file-content">@file.NewDiff</pre>
                                }
                            }
                        }
                    </div>
                }
            }
        </div>
    }

    <!-- Tab: DEPS Audit -->
    @if (_activeTab == "deps")
    {
        <div class="section-card">
            <div class="tab-section-header">
                <span class="section-status @(_review.DepsAudit.Status == SkiaReviewStatus.Pass ? "status-pass" : "status-review")">
                    @(_review.DepsAudit.Status == SkiaReviewStatus.Pass ? "✓ PASS" : "⚠ REVIEW")
                </span>
                <h3 class="section-title">DEPS Audit</h3>
                <span class="skia-section-counts">
                    @if (_review.DepsAudit.Added.Count > 0) { <span class="count-added">+@_review.DepsAudit.Added.Count</span> }
                    @if (_review.DepsAudit.Removed.Count > 0) { <span class="count-removed">-@_review.DepsAudit.Removed.Count</span> }
                    @if (_review.DepsAudit.Changed.Count > 0) { <span class="count-changed">~@_review.DepsAudit.Changed.Count</span> }
                    @if (_review.DepsAudit.Unchanged > 0) { <span class="count-unchanged">@_review.DepsAudit.Unchanged unchanged</span> }
                </span>
            </div>
            @if (!string.IsNullOrEmpty(_review.DepsAudit.Summary))
            {
                <p class="section-summary">@_review.DepsAudit.Summary</p>
            }
            @if (_review.DepsAudit.Recommendations is { Count: > 0 })
            {
                <div class="section-recommendations">
                    <h4>Recommendations</h4>
                    <ul>
                        @foreach (var rec in _review.DepsAudit.Recommendations)
                        {
                            <li>@rec</li>
                        }
                    </ul>
                </div>
            }
            <p>Third-party dependency changes in the DEPS file. The fork pins custom security revisions, so all changes require review.</p>
            @if (_review.DepsAudit.Added.Count > 0)
            {
                <h4 class="change-category cat-added">Added (@_review.DepsAudit.Added.Count)</h4>
                @foreach (var dep in _review.DepsAudit.Added)
                {
                    <div class="skia-dep-entry dep-added">
                        <div class="dep-name">@dep.Name</div>
                        <div class="dep-summary">@dep.Summary</div>
                        @if (dep.Url is not null) { <div class="dep-detail"><code>@dep.Url</code></div> }
                        @if (dep.Revision is not null) { <div class="dep-detail">Revision: <code>@Truncate(dep.Revision)</code></div> }
                    </div>
                }
            }
            @if (_review.DepsAudit.Removed.Count > 0)
            {
                <h4 class="change-category cat-removed">Removed (@_review.DepsAudit.Removed.Count)</h4>
                @foreach (var dep in _review.DepsAudit.Removed)
                {
                    <div class="skia-dep-entry dep-removed">
                        <div class="dep-name">@dep.Name</div>
                        <div class="dep-summary">@dep.Summary</div>
                    </div>
                }
            }
            @if (_review.DepsAudit.Changed.Count > 0)
            {
                <h4 class="change-category cat-changed">Changed (@_review.DepsAudit.Changed.Count)</h4>
                @foreach (var dep in _review.DepsAudit.Changed)
                {
                    <div class="skia-dep-entry dep-changed">
                        <div class="dep-name">@dep.Name</div>
                        <div class="dep-summary">@dep.Summary</div>
                        @if (dep.OldRevision is not null && dep.NewRevision is not null)
                        {
                            <div class="dep-detail">
                                <code>@Truncate(dep.OldRevision)</code> →
                                <code>@Truncate(dep.NewRevision)</code>
                            </div>
                        }
                    </div>
                }
            }
        </div>
    }

    <!-- Tab: Companion PR -->
    @if (_activeTab == "companion" && _review.CompanionPr is not null)
    {
        <div class="section-card">
            <h3 class="section-title">Companion SkiaSharp PR</h3>
            <div class="quick-facts-row">
                <div class="qf-group">
                    <span class="qf-label">PR</span>
                    <a href="https://github.com/mono/SkiaSharp/pull/@_review.CompanionPr.PrNumber" target="_blank" rel="noopener noreferrer" class="label">
                        SkiaSharp #@_review.CompanionPr.PrNumber
                    </a>
                </div>
                @if (_review.CompanionPr.FilesChanged is not null)
                {
                    <div class="qf-group">
                        <span class="qf-label">Files Changed</span>
                        <span class="label">@_review.CompanionPr.FilesChanged</span>
                    </div>
                }
            </div>
            @if (_review.CompanionPr.GeneratedFilesSkipped is { Count: > 0 })
            {
                <h4>Generated Files Skipped</h4>
                <ul class="skia-file-list">
                    @foreach (var file in _review.CompanionPr.GeneratedFilesSkipped)
                    {
                        <li><code>@file</code></li>
                    }
                </ul>
            }
            @if (_review.CompanionPr.Findings is { Count: > 0 })
            {
                <h4>Findings (@_review.CompanionPr.Findings.Count)</h4>
                @foreach (var finding in _review.CompanionPr.Findings)
                {
                    <div class="skia-file-entry file-changed">
                        <div class="file-path"><code>@finding.File</code></div>
                        <div class="file-summary">@finding.Finding</div>
                    </div>
                }
            }
        </div>
    }
}

@code {
    [Parameter] public int Number { get; set; }

    private SkiaReviewReport? _review;
    private SkiaReviewIndexEntry? _indexEntry;
    private bool _loading = true;
    private string _activeTab = "overview";

    private readonly HashSet<string> _expandedDiffs = [];

    protected override async Task OnInitializedAsync()
    {
        var reviewTask = DataService.GetSkiaReviewDetailAsync(Number);
        var indexTask = DataService.GetSkiaUpdatesAsync();
        await Task.WhenAll(reviewTask, indexTask);
        _review = reviewTask.Result;
        var index = indexTask.Result;
        _indexEntry = index?.Reviews.FirstOrDefault(r => r.PrNumber == Number);
        _loading = false;
    }

    private static string FormatBranch(string branch) =>
        branch.StartsWith("chrome/") ? branch["chrome/".Length..] : branch;

    private static string Truncate(string sha) =>
        sha.Length > 12 ? sha[..12] : sha;

    private void ToggleDiff(string key)
    {
        if (!_expandedDiffs.Remove(key))
            _expandedDiffs.Add(key);
    }
}
