@page "/triage/{Number:int}"
@using SkiaSharp.Triage.Dashboard.Helpers
@using static SkiaSharp.Triage.Dashboard.Helpers.TriageFormatHelper
@inject DashboardDataService DataService
@inject NavigationManager Navigation
@inject Microsoft.JSInterop.IJSRuntime JSRuntime

<PageTitle>@(_issueTitle ?? _issue?.Summary ?? $"Issue #{Number}") - SkiaSharp Dashboard</PageTitle>

@if (_loading)
{
    <p><em>Loading triage data...</em></p>
}
else if (_issue is null && _repro is null)
{
    <h1>Issue Not Found</h1>
    <p>No triage or reproduction data for issue #@Number.</p>
    <a href="triage" class="btn-back">← Back to Triage</a>
}
else
{
    <!-- Navigation Bar -->
    <TriageDetailNav BackUrl="@BackUrl" PrevNumber="@_prevNumber" NextNumber="@_nextNumber" 
                     CurrentIndex="@_currentIndex" TotalCount="@_totalCount" DetailUrl="@DetailUrl" />

    <!-- Compact Header -->
    <div class="triage-detail-header triage-detail-header-minimal">
        <div class="detail-title-row">
            @if (_issue is not null)
            {
                <a href="https://github.com/@_issue.Meta.Repo/issues/@_issue.Meta.Number" target="_blank" rel="noopener noreferrer" class="issue-link-lg">#@_issue.Meta.Number</a>
                <h1>@(_issueTitle ?? _issue.Summary)</h1>
            }
            else
            {
                <a href="https://github.com/@(_repro?.Meta.Repo ?? "mono/SkiaSharp")/issues/@Number" target="_blank" rel="noopener noreferrer" class="issue-link-lg">#@Number</a>
                <h1>Issue #@Number</h1>
            }
        </div>
        @if (_issue is not null)
        {
            <div class="detail-header-meta">
                <span class="badge-type badge-@StripPrefix(_issue.Classification.Type.Value)">
                    @FormatLabel(_issue.Classification.Type.Value)
                </span>
                @if (_issue.Evidence.BugSignals?.Severity is not null)
                {
                    <span class="badge-severity badge-sev-@_issue.Evidence.BugSignals.Severity.Value.ToJsonString()">
                        @FormatLabel(_issue.Evidence.BugSignals.Severity.Value.ToJsonString())
                    </span>
                }
                <span class="detail-meta-text">
                    Analyzed: @_issue.Meta.AnalyzedAt.ToString("yyyy-MM-dd HH:mm UTC")
                    · <a href="https://github.com/@_issue.Meta.Repo" target="_blank" rel="noopener noreferrer">@_issue.Meta.Repo</a>
                </span>
            </div>
        }
    </div>

    <!-- Verdict Banner + Corrections -->
    <TriageHero Issue="@_issue" Repro="@_repro" />

    <!-- Two-Column Layout -->
    <div class="triage-detail-layout">
        <!-- Main Column -->
        <div class="triage-main">
            @if (_issue is not null)
            {
                <DetailsTabPanel Issue="@_issue" />
            }
        </div>

        <!-- Sidebar -->
        <div class="triage-sidebar">
            @if (_allActions.Count > 0)
            {
                <div class="sidebar-card">
                    <h3 class="section-title">Actions</h3>
                    @foreach (var action in _allActions)
                    {
                        <div class="action-item">
                            <div class="action-item-header">
                                <span class="badge-action badge-act-@action.Type.ToJsonString()" title="@GetActionTypeTooltip(action.Type)">
                                    @FormatLabel(action.Type.ToJsonString())
                                </span>
                                @if (action.Risk is not null)
                                {
                                    <span class="badge-risk-sm badge-risk-@action.Risk.Value.ToJsonString()">
                                        @FormatLabel(action.Risk.Value.ToJsonString())
                                    </span>
                                }
                            </div>
                            <div class="action-item-body md-content">@MarkdownHelper.ToHtml(action.Description)</div>
                            @if (action.Labels is { Count: > 0 })
                            {
                                <div class="action-item-labels">
                                    @foreach (var lbl in action.Labels)
                                    {
                                        <span class="label">@lbl</span>
                                    }
                                </div>
                            }
                            @if (action.Comment is not null)
                            {
                                <div class="action-item-comment">
                                    <button type="button" class="btn-copy" @onclick="() => CopyToClipboard(action.Comment)">📋 Copy</button>
                                    <div class="md-content draft-content">@MarkdownHelper.ToHtml(action.Comment)</div>
                                </div>
                            }
                            @if (action.LinkedIssue is not null)
                            {
                                <p>Linked: <a href="https://github.com/@(_issue?.Meta.Repo ?? _repro?.Meta.Repo)/issues/@action.LinkedIssue"
                                              target="_blank" rel="noopener noreferrer">#@action.LinkedIssue</a></p>
                            }
                        </div>
                    }
                </div>
            }

            @if (_issue is not null)
            {
                <!-- Quick Facts: Classification -->
                <div class="sidebar-card">
                    <h3 class="section-title">Classification</h3>
                    <dl class="sidebar-dl">
                        <dt>Type</dt>
                        <dd>
                            <span class="badge-type badge-@StripPrefix(_issue.Classification.Type.Value)">@FormatLabel(_issue.Classification.Type.Value)</span>
                            <span class="field-confidence">@_issue.Classification.Type.Confidence.ToString("P0")</span>
                        </dd>
                        @if (_issue.Classification.Area is not null)
                        {
                            <dt>Area</dt>
                            <dd>
                                <span class="label label-area">@FormatLabel(_issue.Classification.Area.Value)</span>
                                <span class="field-confidence">@_issue.Classification.Area.Confidence.ToString("P0")</span>
                            </dd>
                        }
                        @if (_issue.Classification.Platforms is { Count: > 0 })
                        {
                            <dt>Platforms</dt>
                            <dd>@foreach (var p in _issue.Classification.Platforms) { <span class="label label-os">@FormatLabel(p)</span> }</dd>
                        }
                        @if (_issue.Classification.Backends is { Count: > 0 })
                        {
                            <dt>Backends</dt>
                            <dd>@foreach (var b in _issue.Classification.Backends) { <span class="label label-backend">@FormatLabel(b)</span> }</dd>
                        }
                    </dl>
                </div>

                <!-- Quick Facts: Bug Signals -->
                @if (_issue.Evidence.BugSignals is not null)
                {
                    <div class="sidebar-card">
                        <h3 class="section-title">Bug Signals</h3>
                        <dl class="sidebar-dl">
                            @if (_issue.Evidence.BugSignals.Severity is not null)
                            {
                                <dt>Severity</dt>
                                <dd><span class="badge-severity badge-sev-@_issue.Evidence.BugSignals.Severity.Value.ToJsonString()">@FormatLabel(_issue.Evidence.BugSignals.Severity.Value.ToJsonString())</span></dd>
                            }
                            @if (_issue.Evidence.BugSignals.ReproQuality is not null)
                            {
                                <dt>Repro Quality</dt>
                                <dd>@FormatLabel(_issue.Evidence.BugSignals.ReproQuality.Value.ToJsonString())</dd>
                            }
                            @if (_issue.Evidence.BugSignals.RegressionClaimed == true)
                            {
                                <dt>Regression</dt>
                                <dd><span class="signal signal-yes">🔄 Yes</span></dd>
                            }
                            @if (_issue.Evidence.BugSignals.ErrorType is not null)
                            {
                                <dt>Error</dt>
                                <dd><code>@_issue.Evidence.BugSignals.ErrorType.Value.ToJsonString()</code></dd>
                            }
                        </dl>
                    </div>
                }

                <!-- Quick Facts: Regression -->
                @if (_issue.Evidence.Regression is not null)
                {
                    <div class="sidebar-card">
                        <h3 class="section-title">Regression</h3>
                        <dl class="sidebar-dl">
                            <dt>Status</dt>
                            <dd>
                                @if (_issue.Evidence.Regression.IsRegression)
                                {
                                    <span class="badge-regression">⚡ Regression</span>
                                    <span class="field-confidence">@_issue.Evidence.Regression.Confidence.ToString("P0")</span>
                                }
                                else
                                {
                                    <span>Not a regression</span>
                                }
                            </dd>
                            @if (_issue.Evidence.Regression.WorkedInVersion is not null)
                            {
                                <dt>Worked in</dt>
                                <dd>@_issue.Evidence.Regression.WorkedInVersion</dd>
                            }
                            @if (_issue.Evidence.Regression.BrokeInVersion is not null)
                            {
                                <dt>Broke in</dt>
                                <dd>@_issue.Evidence.Regression.BrokeInVersion</dd>
                            }
                        </dl>
                    </div>
                }

                <!-- Quick Facts: Version Analysis -->
                @if (_issue.Evidence.VersionAnalysis is not null)
                {
                    <div class="sidebar-card">
                        <h3 class="section-title">Version Analysis</h3>
                        <dl class="sidebar-dl">
                            @if (_issue.Evidence.VersionAnalysis.MentionedVersions is { Count: > 0 })
                            {
                                <dt>Versions</dt>
                                <dd>@foreach (var v in _issue.Evidence.VersionAnalysis.MentionedVersions) { <span class="label">@v</span> }</dd>
                            }
                            @if (_issue.Evidence.VersionAnalysis.CurrentRelevance is not null)
                            {
                                <dt>Relevant</dt>
                                <dd><span class="label label-relevance-@_issue.Evidence.VersionAnalysis.CurrentRelevance.Value.ToJsonString()">@FormatLabel(_issue.Evidence.VersionAnalysis.CurrentRelevance.Value.ToJsonString())</span></dd>
                            }
                            @if (_issue.Evidence.VersionAnalysis.WorkedIn is not null)
                            {
                                <dt>Worked in</dt>
                                <dd>@_issue.Evidence.VersionAnalysis.WorkedIn</dd>
                            }
                            @if (_issue.Evidence.VersionAnalysis.BrokeIn is not null)
                            {
                                <dt>Broke in</dt>
                                <dd>@_issue.Evidence.VersionAnalysis.BrokeIn</dd>
                            }
                        </dl>
                    </div>
                }
            }

            <!-- Reproduction Result -->
            @if (_repro is not null)
            {
                <div class="sidebar-card">
                    <h3 class="section-title">Reproduction</h3>
                    <dl class="sidebar-dl">
                        <dt>Conclusion</dt>
                        <dd>
                            <span class="badge-repro-conclusion badge-repro-@_repro.Conclusion.ToJsonString()">
                                @FormatLabel(_repro.Conclusion.ToJsonString())
                            </span>
                            @if (_repro.Assessment is not null)
                            {
                                <span class="badge-assessment">@FormatLabel(_repro.Assessment.Value.ToJsonString())</span>
                            }
                        </dd>
                        @if (_repro.ReproductionSteps is { Count: > 0 })
                        {
                            <dt>Steps</dt>
                            <dd>@_repro.ReproductionSteps.Count steps</dd>
                        }
                        @if (_repro.Environment?.Os is not null)
                        {
                            <dt>Environment</dt>
                            <dd>@_repro.Environment.Os @_repro.Environment?.Arch</dd>
                        }
                    </dl>
                    @if (_repro.Output?.MissingInfo is { Count: > 0 })
                    {
                        <div class="repro-missing-indicator">
                            ⚠ Missing info (@_repro.Output.MissingInfo.Count)
                        </div>
                    }
                </div>

                <!-- Draft Response Preview -->
                @if (_repro.Output?.ProposedResponse is not null)
                {
                    var response = _repro.Output.ProposedResponse;
                    <div class="sidebar-card">
                        <h3 class="section-title">Draft Response</h3>
                        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:0.5rem;">
                            <span class="badge-rs badge-rs-@response.Status.ToJsonString()">@FormatLabel(response.Status.ToJsonString())</span>
                        </div>
                        @if (response.Summary is not null)
                        {
                            <p class="draft-summary">@response.Summary</p>
                        }
                        <div class="draft-actions">
                            <button type="button" class="btn-copy" @onclick="() => CopyToClipboard(response.Body)" title="Copy markdown to clipboard">
                                📋 Copy
                            </button>
                            <a href="https://github.com/@(_issue?.Meta.Repo ?? _repro.Meta.Repo)/issues/@(_issue?.Meta.Number ?? _repro.Meta.Number)"
                               target="_blank" rel="noopener noreferrer" class="btn-goto">
                                GitHub ↗
                            </a>
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    <!-- Full-Width Draft Response -->
    @if (_repro?.Output?.ProposedResponse is not null)
    {
        var response = _repro.Output.ProposedResponse;
        <div class="section-card draft-response-full">
            <h3 class="section-title">Draft Response</h3>
            <div class="draft-body-full md-content">
                @MarkdownHelper.ToHtml(response.Body)
            </div>
        </div>
    }

    <!-- Repro Log Toggle -->
    @if (_repro is not null)
    {
        <div class="repro-log-toggle">
            <button type="button" class="btn-toggle-repro" @onclick="() => _showReproLog = !_showReproLog">
                @(_showReproLog ? "▲ Hide Repro Log" : "▼ Show Repro Log")
            </button>
        </div>
        @if (_showReproLog)
        {
            <ReproTabPanel Repro="@_repro" ActiveTab="details" />
        }
    }

    <!-- Bottom Navigation -->
    <TriageDetailNav BackUrl="@BackUrl" PrevNumber="@_prevNumber" NextNumber="@_nextNumber" 
                     CurrentIndex="@_currentIndex" TotalCount="@_totalCount" DetailUrl="@DetailUrl" IsBottom="true" />
}

@code {
    [Parameter] public int Number { get; set; }

    [SupplyParameterFromQuery] public string? Action { get; set; }
    [SupplyParameterFromQuery] public string? Type { get; set; }
    [SupplyParameterFromQuery] public string? Area { get; set; }
    [SupplyParameterFromQuery] public string? Severity { get; set; }
    [SupplyParameterFromQuery] public string? Repro { get; set; }
    [SupplyParameterFromQuery] public string? Sort { get; set; }
    [SupplyParameterFromQuery] public string? Card { get; set; }

    private TriageIndex? _index;
    private TriagedIssue? _issue;
    private ReproResult? _repro;
    private string? _issueTitle;
    private int? _prevNumber;
    private int? _nextNumber;
    private int _currentIndex;
    private int _totalCount;
    private bool _loading = true;
    private bool _showReproLog;
    private List<TriageAction> _allActions = [];

    protected override async Task OnInitializedAsync()
    {
        var indexTask = DataService.GetTriageIndexAsync();
        var triageTask = DataService.GetTriageDetailAsync(Number);
        var reproTask = DataService.GetReproDetailAsync(Number);

        await Task.WhenAll(indexTask, triageTask, reproTask);

        _index = indexTask.Result;
        _issue = triageTask.Result;
        _repro = reproTask.Result;
        _issueTitle = _index?.Issues.FirstOrDefault(i => i.Number == Number)?.IssueTitle;
        RebuildActions();
        LoadNavigation();
        _loading = false;
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!_loading)
        {
            _issue = await DataService.GetTriageDetailAsync(Number);
            _repro = await DataService.GetReproDetailAsync(Number);
            _issueTitle = _index?.Issues.FirstOrDefault(i => i.Number == Number)?.IssueTitle;
            _showReproLog = false;
            RebuildActions();
            LoadNavigation();
        }
    }

    private void RebuildActions()
    {
        _allActions = [];
        if (_issue?.Output?.Actions is not null) _allActions.AddRange(_issue.Output.Actions);
        if (_repro?.Output?.Actions is not null) _allActions.AddRange(_repro.Output.Actions);
    }

    private async Task CopyToClipboard(string? text)
    {
        if (string.IsNullOrEmpty(text)) return;
        try { await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", text); }
        catch { }
    }

    private void LoadNavigation()
    {
        if (_index is null) return;

        var filtered = ApplyFilters(_index.Issues);
        _totalCount = filtered.Count;
        _currentIndex = filtered.FindIndex(i => i.Number == Number);

        if (_currentIndex >= 0)
        {
            _prevNumber = _currentIndex > 0 ? filtered[_currentIndex - 1].Number : null;
            _nextNumber = _currentIndex < filtered.Count - 1 ? filtered[_currentIndex + 1].Number : null;
        }
        else
        {
            _prevNumber = null;
            _nextNumber = null;
            _totalCount = _index.Issues.Count;
            _currentIndex = _index.Issues.FindIndex(i => i.Number == Number);
        }
    }

    private List<TriageIndexEntry> ApplyFilters(List<TriageIndexEntry> issues)
    {
        var query = issues.AsEnumerable();

        if (!string.IsNullOrEmpty(Card))
        {
            query = Card switch
            {
                "needs-investigation" => query.Where(i => i.Action == "needs-investigation"),
                "closeable" => query.Where(i => i.Closeable),
                "quick-wins" => query.Where(i => i.Closeable),
                "regressions" => query.Where(i => i.IsRegression),
                "has-repro" => query.Where(i => i.HasRepro),
                _ => query
            };
        }

        if (!string.IsNullOrEmpty(Action))
            query = query.Where(i => i.Action == Action);
        if (!string.IsNullOrEmpty(Type))
            query = query.Where(i => i.Type == Type);
        if (!string.IsNullOrEmpty(Area))
            query = query.Where(i => i.Area == Area);
        if (!string.IsNullOrEmpty(Severity))
            query = query.Where(i => i.Severity == Severity);
        if (!string.IsNullOrEmpty(Repro))
        {
            query = Repro switch
            {
                "has-repro" => query.Where(i => i.HasRepro),
                _ => query.Where(i => i.ReproConclusion == Repro)
            };
        }

        var sort = Sort ?? "newest";
        query = sort switch
        {
            "confidence" => query.OrderByDescending(i => i.Confidence ?? 0),
            "severity" => query.OrderByDescending(i => SeverityOrder(i.Severity)),
            _ => query.OrderByDescending(i => i.Number)
        };

        return query.ToList();
    }

    private string BackUrl
    {
        get
        {
            var parts = new List<string>();
            if (!string.IsNullOrEmpty(Card)) parts.Add($"card={Card}");
            if (!string.IsNullOrEmpty(Action)) parts.Add($"action={Action}");
            if (!string.IsNullOrEmpty(Type)) parts.Add($"type={Type}");
            if (!string.IsNullOrEmpty(Area)) parts.Add($"area={Area}");
            if (!string.IsNullOrEmpty(Severity)) parts.Add($"severity={Severity}");
            if (!string.IsNullOrEmpty(Repro)) parts.Add($"repro={Repro}");
            if (!string.IsNullOrEmpty(Sort) && Sort != "newest") parts.Add($"sort={Sort}");
            return parts.Count > 0 ? $"triage?{string.Join('&', parts)}" : "triage";
        }
    }

    private string DetailUrl(int number)
    {
        var parts = new List<string>();
        if (!string.IsNullOrEmpty(Card)) parts.Add($"card={Card}");
        if (!string.IsNullOrEmpty(Action)) parts.Add($"action={Action}");
        if (!string.IsNullOrEmpty(Type)) parts.Add($"type={Type}");
        if (!string.IsNullOrEmpty(Area)) parts.Add($"area={Area}");
        if (!string.IsNullOrEmpty(Severity)) parts.Add($"severity={Severity}");
        if (!string.IsNullOrEmpty(Repro)) parts.Add($"repro={Repro}");
        if (!string.IsNullOrEmpty(Sort) && Sort != "newest") parts.Add($"sort={Sort}");
        return parts.Count > 0 ? $"triage/{number}?{string.Join('&', parts)}" : $"triage/{number}";
    }

    private static int SeverityOrder(string? severity) => TriageFormatHelper.SeverityOrder(severity);
}
