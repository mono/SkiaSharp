<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>$(TFMCurrent)</TargetFrameworks>
    <TargetFrameworks Condition="$(IsWindows)">$(TargetFrameworks);net48</TargetFrameworks>
    <DefineConstants>$(DefineConstants);USE_LIBRARY_LOADER</DefineConstants>
    <DefineConstants Condition="$(TargetFramework.StartsWith('net4'))">$(DefineConstants);SYSTEM_DRAWING</DefineConstants>
    <RootNamespace>SkiaSharp.Tests</RootNamespace>
    <AssemblyName>SkiaSharp.Tests</AssemblyName>
    <OutputType>Exe</OutputType>
    <TestingPlatformDotnetTestSupport>true</TestingPlatformDotnetTestSupport>
    <UseMicrosoftTestingPlatformRunner>true</UseMicrosoftTestingPlatformRunner>
    <SkipGenerateAssemblyVersionInfo>true</SkipGenerateAssemblyVersionInfo>
    <SkipMDocGenerateDocs>true</SkipMDocGenerateDocs>
    <Platforms>AnyCPU;x64;x86</Platforms>
  </PropertyGroup>

  <PropertyGroup Condition="$([MSBuild]::IsTargetFrameworkCompatible('$(TargetFramework)', 'net7.0'))">
    <DefineConstants>$(DefineConstants);USE_LIBRARY_IMPORT</DefineConstants>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="xunit.v3" Version="3.2.2" />
    <PackageReference Include="Microsoft.Testing.Extensions.TrxReport" Version="1.9.1" />
    <PackageReference Include="Microsoft.Testing.Extensions.HangDump" Version="1.9.1" />
    <PackageReference Include="coverlet.msbuild" Version="10.0.0" />
    <PackageReference Include="System.Net.Http" Version="4.3.4" Condition="$(TargetFramework.StartsWith('net4'))" />
  </ItemGroup>

  <!--
    Software Vulkan for the Windows test legs (both .NET Framework and .NET Core).

    The headless Windows CI agents have no registered Vulkan ICD (and no guaranteed
    loader), so every ganesh-vulkan cell skips. These first-party, Apache-2.0 Silk.NET
    native packages provide a software ICD (SwiftShader: vk_swiftshader.dll +
    vk_swiftshader_icd.json) and the Khronos loader (vulkan-1.dll). We copy the correct
    bitness next to the test host so the Vulkan tests EXECUTE and golden-compare,
    mirroring the Linux leg's Mesa lavapipe provisioning.

    We deliberately take only the native assets (ExcludeAssets=build) and copy them
    ourselves so net48 and net-current behave identically (the packages' own MSBuild
    targets ship for net461 only). VulkanIcdEnvironmentFixture then points the loader at
    the copied manifest. A missing/broken ICD or loader just makes the Vulkan cells skip
    (see tests/VulkanTests/VKTest.cs), so this can only add coverage, never turn the
    build red. Windows-only; a no-op on Linux/Android/macOS legs.
  -->
  <ItemGroup Condition="'$(OS)' == 'Windows_NT'">
    <PackageReference Include="Silk.NET.Vulkan.Loader.Native" Version="2025.9.12" GeneratePathProperty="true" PrivateAssets="all" ExcludeAssets="build;buildTransitive" />
    <PackageReference Include="Silk.NET.Vulkan.SwiftShader.Native" Version="2025.9.8" GeneratePathProperty="true" PrivateAssets="all" ExcludeAssets="build;buildTransitive" />
  </ItemGroup>

  <!-- 64-bit host: x64, or AnyCPU (netcore leg) running as a 64-bit process. -->
  <ItemGroup Condition="'$(OS)' == 'Windows_NT' and '$(Platform)' != 'x86'">
    <Content Include="$(PkgSilk_NET_Vulkan_Loader_Native)\runtimes\win-x64\native\vulkan-1.dll" Link="vulkan-1.dll" CopyToOutputDirectory="PreserveNewest" Visible="false" />
    <Content Include="$(PkgSilk_NET_Vulkan_SwiftShader_Native)\runtimes\win-x64\native\vk_swiftshader.dll" Link="vk_swiftshader.dll" CopyToOutputDirectory="PreserveNewest" Visible="false" />
    <Content Include="$(PkgSilk_NET_Vulkan_SwiftShader_Native)\runtimes\win-x64\native\vk_swiftshader_icd.json" Link="vk_swiftshader_icd.json" CopyToOutputDirectory="PreserveNewest" Visible="false" />
  </ItemGroup>

  <!-- 32-bit host: the .NET Framework leg also runs an x86 pass. -->
  <ItemGroup Condition="'$(OS)' == 'Windows_NT' and '$(Platform)' == 'x86'">
    <Content Include="$(PkgSilk_NET_Vulkan_Loader_Native)\runtimes\win-x86\native\vulkan-1.dll" Link="vulkan-1.dll" CopyToOutputDirectory="PreserveNewest" Visible="false" />
    <Content Include="$(PkgSilk_NET_Vulkan_SwiftShader_Native)\runtimes\win-x86\native\vk_swiftshader.dll" Link="vk_swiftshader.dll" CopyToOutputDirectory="PreserveNewest" Visible="false" />
    <Content Include="$(PkgSilk_NET_Vulkan_SwiftShader_Native)\runtimes\win-x86\native\vk_swiftshader_icd.json" Link="vk_swiftshader_icd.json" CopyToOutputDirectory="PreserveNewest" Visible="false" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\binding\HarfBuzzSharp\HarfBuzzSharp.csproj" />
    <ProjectReference Include="..\..\binding\SkiaSharp.SceneGraph\SkiaSharp.SceneGraph.csproj" />
    <ProjectReference Include="..\..\binding\SkiaSharp.Resources\SkiaSharp.Resources.csproj" />
    <ProjectReference Include="..\..\binding\SkiaSharp.Skottie\SkiaSharp.Skottie.csproj" />
    <ProjectReference Include="..\..\binding\SkiaSharp\SkiaSharp.csproj" />
    <ProjectReference Include="..\..\source\SkiaSharp.HarfBuzz\SkiaSharp.HarfBuzz\SkiaSharp.HarfBuzz.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="..\Tests\**\*.cs" Link="%(RecursiveDir)%(FileName)%(Extension)" />
    <Compile Include="..\..\binding\Binding.Shared\LibraryLoader.cs" Link="Utils\LibraryLoader.cs" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="..\Content\**\*" Link="Content\%(RecursiveDir)%(FileName)%(Extension)" CopyToOutputDirectory="Always" />
    <None Remove="TestResults\**" />
  </ItemGroup>

  <Import Project="..\..\binding\IncludeNativeAssets.SkiaSharp.targets" />
  <Import Project="..\..\binding\IncludeNativeAssets.HarfBuzzSharp.targets" />

</Project>
