<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0-ios26.0</TargetFramework>
    <OutputType>Exe</OutputType>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <RootNamespace>SkiaSharp.Tests.RenderHost.iOS</RootNamespace>
    <AssemblyName>RenderHost.iOS</AssemblyName>
    <SkipGenerateAssemblyVersionInfo>true</SkipGenerateAssemblyVersionInfo>
    <SkipMDocGenerateDocs>true</SkipMDocGenerateDocs>
    <SupportedOSPlatformVersion>14.2</SupportedOSPlatformVersion>
    <DefineConstants>$(DefineConstants);USE_LIBRARY_IMPORT</DefineConstants>

    <ApplicationId>com.skiasharp.renderhost.ios</ApplicationId>
    <ApplicationTitle>SkiaSharp Render Host</ApplicationTitle>
    <ApplicationVersion>1</ApplicationVersion>
    <ApplicationDisplayVersion>1.0</ApplicationDisplayVersion>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\binding\SkiaSharp\SkiaSharp.csproj" />
  </ItemGroup>

  <Import Project="..\..\..\binding\IncludeNativeAssets.SkiaSharp.targets" />

  <!-- Compile-include scene + renderer sources from the in-process tests
       so a scene change updates desktop AND iOS in one edit. The Metal
       renderers' OS gate (IsOSPlatform("IOS")/"TVOS"/OSX) already passes
       on iOS — reuse them as-is. -->
  <ItemGroup>
    <Compile Include="..\..\Tests\SkiaSharp\Visual\Scenes\*.cs" Link="Scenes\%(Filename)%(Extension)" />

    <Compile Include="..\..\Tests\SkiaSharp\Visual\Renderers\IRenderer.cs"              Link="Renderers\IRenderer.cs" />
    <Compile Include="..\..\Tests\SkiaSharp\Visual\Renderers\RasterRenderer.cs"         Link="Renderers\RasterRenderer.cs" />
    <Compile Include="..\..\Tests\SkiaSharp\Visual\Renderers\GaneshMetalRenderer.cs"    Link="Renderers\GaneshMetalRenderer.cs" />
    <Compile Include="..\..\Tests\SkiaSharp\Visual\Renderers\GraphiteMetalRenderer.cs"  Link="Renderers\GraphiteMetalRenderer.cs" />
  </ItemGroup>

</Project>
