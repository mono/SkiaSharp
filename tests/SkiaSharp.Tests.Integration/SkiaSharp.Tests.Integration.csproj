<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <OutputType>Exe</OutputType>
    <TestingPlatformDotnetTestSupport>true</TestingPlatformDotnetTestSupport>
    <UseMicrosoftTestingPlatformRunner>true</UseMicrosoftTestingPlatformRunner>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
    <RootNamespace>SkiaSharp.Tests.Integration</RootNamespace>
    <AssemblyVersion>1.0.0.0</AssemblyVersion>
    <Version>1.0.0</Version>
    
    <!-- Package versions must be specified explicitly; there is no default and no floating ("*")
         version. The release pipeline / release-testing skill passes the exact version under test
         (e.g. dotnet test -p:SkiaSharpVersion=X.Y.Z -p:HarfBuzzSharpVersion=X.Y.Z.N). A bare run
         with no version fails fast via the ValidateVersions target below. -->
    <SkiaSharpVersion Condition="'$(SkiaSharpVersion)' == ''"></SkiaSharpVersion>
    <HarfBuzzSharpVersion Condition="'$(HarfBuzzSharpVersion)' == ''"></HarfBuzzSharpVersion>
    
    <!-- Device configuration - can be overridden via command line -->
    <!-- dotnet test -p:iOSDevice="iPad Pro 13-inch (M4)" -p:iOSVersion="18.5" -->
    <!-- dotnet test -p:AndroidDevice="Pixel 8" -p:AndroidVersion="14" -p:AndroidDeviceId="emulator-5554" -p:AndroidApiLevel="23" -->
    <iOSDevice Condition="'$(iOSDevice)' == ''"></iOSDevice>
    <iOSVersion Condition="'$(iOSVersion)' == ''"></iOSVersion>
    <AndroidDevice Condition="'$(AndroidDevice)' == ''"></AndroidDevice>
    <AndroidVersion Condition="'$(AndroidVersion)' == ''"></AndroidVersion>
    <!-- AndroidDeviceId: Specific emulator/device UDID (e.g., "emulator-5554") -->
    <AndroidDeviceId Condition="'$(AndroidDeviceId)' == ''"></AndroidDeviceId>
    <!-- AndroidApiLevel: Expected API level for validation (e.g., "23", "36") -->
    <AndroidApiLevel Condition="'$(AndroidApiLevel)' == ''"></AndroidApiLevel>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Appium.WebDriver" Version="5.1.0" />
    <PackageReference Include="Microsoft.Playwright" Version="1.49.0" />
    <PackageReference Include="xunit.v3" Version="3.2.2" />
    <PackageReference Include="Microsoft.Testing.Extensions.TrxReport" Version="1.9.1" />
    <PackageReference Include="Microsoft.Testing.Extensions.HangDump" Version="1.9.1" />
    <PackageReference Include="SkiaSharp.Extended" Version="3.1.0-preview.3" />
  </ItemGroup>

  <!-- SkiaSharp packages - version must be specified -->
  <ItemGroup Condition="'$(SkiaSharpVersion)' != ''">
    <PackageReference Include="SkiaSharp" Version="$(SkiaSharpVersion)" />
    <PackageReference Include="HarfBuzzSharp" Version="$(HarfBuzzSharpVersion)" />
  </ItemGroup>

  <!-- Test assets -->
  <ItemGroup>
    <EmbeddedResource Include="Assets\*.png" />
  </ItemGroup>

  <!-- Pass configuration to test runtime via RuntimeHostConfigurationOption -->
  <ItemGroup>
    <RuntimeHostConfigurationOption Include="SkiaSharpVersion" Value="$(SkiaSharpVersion)" />
    <RuntimeHostConfigurationOption Include="HarfBuzzSharpVersion" Value="$(HarfBuzzSharpVersion)" />
    <RuntimeHostConfigurationOption Include="iOSDevice" Value="$(iOSDevice)" />
    <RuntimeHostConfigurationOption Include="iOSVersion" Value="$(iOSVersion)" />
    <RuntimeHostConfigurationOption Include="AndroidDevice" Value="$(AndroidDevice)" />
    <RuntimeHostConfigurationOption Include="AndroidVersion" Value="$(AndroidVersion)" />
    <RuntimeHostConfigurationOption Include="AndroidDeviceId" Value="$(AndroidDeviceId)" />
    <RuntimeHostConfigurationOption Include="AndroidApiLevel" Value="$(AndroidApiLevel)" />
  </ItemGroup>

  <!-- Error if versions not specified -->
  <Target Name="ValidateVersions" BeforeTargets="Restore;Build">
    <Error Condition="'$(SkiaSharpVersion)' == ''" 
           Text="SkiaSharpVersion must be specified. Use: dotnet test -p:SkiaSharpVersion=X.Y.Z -p:HarfBuzzSharpVersion=X.Y.Z.N" />
    <Error Condition="'$(HarfBuzzSharpVersion)' == ''" 
           Text="HarfBuzzSharpVersion must be specified. Use: dotnet test -p:SkiaSharpVersion=X.Y.Z -p:HarfBuzzSharpVersion=X.Y.Z.N" />
    <Message Importance="High" Text="Testing SkiaSharp $(SkiaSharpVersion) with HarfBuzzSharp $(HarfBuzzSharpVersion)" />
  </Target>

</Project>
